@using Microsoft.AspNetCore.Components.Web
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["lib/bootstrap/dist/css/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["Project65.Web.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <script>
        (function() {
            const theme = localStorage.getItem('theme');
            if (theme === 'light') document.documentElement.classList.add('light-theme');
        })();
    </script>
    <script src="@("https://cdn.jsdelivr.net/npm/@mux/mux-player")"></script>
    <script src="@("https://unpkg.com/@mux/upchunk@3")"></script>
    <link href="https://releases.transloadit.com/uppy/v3.21.0/uppy.min.css" rel="stylesheet">
    <script src="https://releases.transloadit.com/uppy/v3.21.0/uppy.min.js"></script>
    <HeadOutlet @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />
    <script src="js/upload.js"></script>
    <script src="js/theme.js"></script>
    <script src="js/fullscreen.js"></script>
</head>

<body>
    <CascadingAuthenticationState>
        <Routes @rendermode="@(new InteractiveServerRenderMode(prerender: false))" />
    </CascadingAuthenticationState>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
