@inject NavigationManager Navigation
@rendermode RenderMode.InteractiveServer

<header class="top-nav">
    <div style="display: flex; align-items: center; justify-content: space-between; width: 100%; @(NavOpenClass == "active" ? "margin-bottom: 1rem;" : "")">
            <a href="/" class="brand">
                PROJECT<span>65</span> STUDIOS
            </a>
            <button class="nav-toggle" @onclick="ToggleNav">
                <span class="bar"></span>
                <span class="bar"></span>
                <span class="bar"></span>
            </button>
    </div>
    
    <div class="nav-overlay @NavOpenClass" @onclick="ToggleNav"></div>

    <div class="nav-menu @NavOpenClass">
        <div class="nav-menu-header">
            <span style="font-weight: 800; font-size: 1.25rem; letter-spacing: 1px;">MENU</span>
            <button class="nav-close-btn" @onclick="ToggleNav">✕</button>
        </div>

        <input type="text" class="search-bar" placeholder="Search this event..." />
        
        <div class="nav-links">
            <ThemeToggle />

            <AuthorizeView>
                <Authorized>
                    <a href="/admin/events" class="btn-secondary" style="padding: 0.5rem 1rem; font-size: 0.9rem;">Admin</a>
                    <form action="/Account/Logout" method="post" style="display:inline; width: 100%;">
                        <AntiforgeryToken />
                        <input type="hidden" name="ReturnUrl" value="@("/" + Navigation.ToBaseRelativePath(Navigation.BaseUri))" />
                        <button type="submit" class="btn-secondary" style="padding: 0.5rem 1rem; font-size: 0.9rem; width: 100%;">Logout</button>
                    </form>
                </Authorized>
                <NotAuthorized>
                        <a href="/Account/Login" class="btn-secondary" style="padding: 0.5rem 1rem; font-size: 0.9rem;">Login</a>
                </NotAuthorized>
            </AuthorizeView>
            <button class="cart-btn">Cart</button>
        </div>
    </div>
</header>

@code {
    private bool _isNavOpen = false;
    private string NavOpenClass => _isNavOpen ? "active" : "";

    private void ToggleNav()
    {
        _isNavOpen = !_isNavOpen;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
                // Reset nav on navigation
                Navigation.LocationChanged += (s, e) => 
                {
                    _isNavOpen = false;
                    StateHasChanged();
                };
        }
    }
}
