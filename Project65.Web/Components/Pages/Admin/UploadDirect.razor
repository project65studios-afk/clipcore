@page "/admin/upload-direct"
@using Microsoft.AspNetCore.Authorization
@using Project65.Core.Interfaces
@using Project65.Web.Services
@using Project65.Core.Entities
@inject IJSRuntime JSRuntime
@inject IEventRepository EventRepository
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Direct Upload (1080p) - Project65 Admin</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1" style="color: var(--text-main);">Direct Upload (High Quality)</h1>
            <p class="mb-0" style="color: var(--text-main); opacity: 0.7;">Upload pure 1080p masters directly to Mux. No server compression.</p>
        </div>
        <div class="d-flex gap-2">
            @if (!string.IsNullOrEmpty(EventId))
            {
                <a href="/events/@EventId" target="_blank" class="btn btn-outline-primary btn-sm">
                    View Event Page <i class="bi bi-box-arrow-up-right ms-1"></i>
                </a>
            }
            <a href="/admin/upload" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Back to Legacy Upload
            </a>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-8">
            <div class="card" style="background: var(--bg-surface); border: 1px solid var(--border-color);">
                <div class="card-header border-bottom border-secondary bg-transparent">
                    <h5 class="mb-0" style="color: var(--accent-primary);"><i class="bi bi-sliders me-2"></i>Using Event Settings</h5>
                </div>
                <div class="card-body">
                    <p class="small mb-3" style="color: var(--text-main); opacity: 0.8;">
                        Uploads will automatically inherit the following settings from the event. 
                        <strong>To change these, go back to <a href="/admin/upload?EventId=@EventId" style="color: var(--accent-primary);">Standard Upload</a> and update Event Settings.</strong>
                    </p>
                    <div class="row g-3">
                        <div class="col-6 col-md-3">
                            <label class="form-label small" style="color: var(--text-main); opacity: 0.7;">Personal Price</label>
                            <div class="fw-bold" style="color: var(--text-main);">$@(_priceDollars.ToString("N2"))</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label small" style="color: var(--text-main); opacity: 0.7;">Commercial Price</label>
                            <div class="fw-bold" style="color: var(--text-main);">$@(_priceCommercialDollars.ToString("N2"))</div>
                        </div>
                        <div class="col-6 col-md-3">
                            <label class="form-label small" style="color: var(--text-main); opacity: 0.7;">GIF Sales</label>
                            <div class="fw-bold" style="@(_allowGifSale ? "color: var(--status-success);" : "color: var(--text-main); opacity: 0.5;")">
                                @(_allowGifSale ? "Enabled" : "Disabled")
                            </div>
                        </div>
                         @if (_allowGifSale)
                         {
                            <div class="col-6 col-md-3">
                                <label class="form-label small" style="color: var(--text-main); opacity: 0.7;">GIF Price</label>
                                <div class="fw-bold" style="color: var(--text-main);">$@(_gifPriceDollars.ToString("N2"))</div>
                            </div>
                         }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Upload Area -->
    <div class="row">
        <div class="col-12">
            <div class="card" style="background: var(--bg-surface); border: 1px solid var(--border-color);">
                <div class="card-body p-0">
                    <div id="uppy-direct-dashboard"></div>
                </div>
            </div>
        </div>
        
        <!-- Status / Logs Area -->
        <div class="col-12 mt-4">
            <div class="card" style="background: var(--bg-surface); border: 1px solid var(--border-color);">
                <div class="card-header border-bottom border-secondary bg-transparent d-flex justify-content-between align-items-center">
                    <h5 class="mb-0" style="color: var(--text-main);">Session Log</h5>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearLogs">Clear</button>
                </div>
                <div class="card-body font-monospace" style="max-height: 300px; overflow-y: auto; font-size: 0.85rem; color: var(--text-main);">
                     @if (_logs.Count == 0)
                     {
                         <div class="text-center py-4" style="color: var(--text-main); opacity: 0.5;">Waiting for uploads...</div>
                     }
                     else
                     {
                         @foreach (var log in _logs)
                         {
                             <div class="mb-1 @log.ColorClass">
                                 <span class="small" style="color: var(--text-main); opacity: 0.7;">@log.Time</span> @log.Message
                             </div>
                         }
                     }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Theme-aware Uppy Overrides */
    .uppy-Dashboard-inner {
        background-color: var(--bg-surface) !important;
        border: 1px solid var(--border-color) !important;
    }
    .uppy-Dashboard-AddFiles-title {
        color: var(--text-main) !important;
    }
    .uppy-DashboardTab-btn {
        color: var(--text-main) !important;
        opacity: 0.7;
    }
    .uppy-DashboardTab-btn:hover {
        background-color: var(--bg-subtle) !important;
        opacity: 1;
    }
</style>

@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider

@code {
    [SupplyParameterFromQuery]
    public string? EventId { get; set; }

    private List<LogEntry> _logs = new();
    private IJSObjectReference? _module;
    private string _userId = "Admin";
    private double _priceDollars;
    private double _priceCommercialDollars;
    private bool _allowGifSale;
    private double _gifPriceDollars;

    public class UploadInfo
    {
        public string EventId { get; set; } = "";
        public int PriceCents { get; set; }
        public int PriceCommercialCents { get; set; }
        public bool AllowGifSale { get; set; }
        public int GifPriceCents { get; set; }
        public string UserId { get; set; } = "";
    }

    [JSInvokable]
    public Task<UploadInfo> GetUploadInfo()
    {
        return Task.FromResult(new UploadInfo
        {
            EventId = EventId ?? "",
            PriceCents = (int)(_priceDollars * 100),
            PriceCommercialCents = (int)(_priceCommercialDollars * 100),
            AllowGifSale = _allowGifSale,
            GifPriceCents = (int)(_gifPriceDollars * 100),
            UserId = _userId
        });
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "Admin";

        if (string.IsNullOrEmpty(EventId))
        {
            AddLog("WARNING: No Event ID selected. Uploads will fail.", "text-warning");
        }
        else
        {
            var evt = await EventRepository.GetByIdAsync(EventId);
            if (evt != null)
            {
                _priceDollars = evt.DefaultPriceCents / 100.00;
                _priceCommercialDollars = evt.DefaultPriceCommercialCents / 100.00;
                _allowGifSale = evt.DefaultAllowGifSale;
                _gifPriceDollars = evt.DefaultGifPriceCents / 100.00;
                
                AddLog($"Linked to Event: {evt.Name}", "text-info");
                AddLog($"Using Defaults: Personal=${_priceDollars}, Comm=${_priceCommercialDollars}, GIFs={(_allowGifSale ? "Yes" : "No")}", "text-secondary");
            }
            else
            {
                AddLog($"ERROR: Event {EventId} not found!", "text-danger");
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Import the module
                _module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "/js/upload-direct.js");
                
                // Initialize Uppy with EventId and UserId
                await _module.InvokeVoidAsync("initDirectUpload", DotNetObjectReference.Create(this), EventId, _userId);
                
                AddLog("Ready for uploads.", "text-success");
            }
            catch (Exception ex)
            {
                AddLog($"Initialization Error: {ex.Message}", "text-danger");
            }
        }
    }

    [JSInvokable]
    public Task<string> GetR2UploadUrl(string fileName, string contentType)
    {
        // Use a standardized path for thumbnails
        var key = $"thumbnails/{fileName}";
        var url = StorageService.GetPresignedUploadUrl(key, contentType);
        
        if (string.IsNullOrEmpty(url))
        {
             throw new Exception("Server failed to generate R2 Upload URL (Check server logs for S3/R2 config errors).");
        }
        
        // Return JSON object expected by JS
        var result = System.Text.Json.JsonSerializer.Serialize(new { url, key });
        return Task.FromResult(result);
    }
    
    [Inject] 
    public IStorageService StorageService { get; set; } = default!;

    [JSInvokable]
    public void LogInfo(string message)
    {
        AddLog(message, "text-info");
        StateHasChanged();
    }
    
    [JSInvokable]
    public void LogSuccess(string message)
    {
        AddLog(message, "text-success");
        StateHasChanged();
    }
    
    [JSInvokable]
    public void LogError(string message)
    {
        AddLog(message, "text-danger");
        StateHasChanged();
    }

    private void AddLog(string msg, string colorClass)
    {
        _logs.Insert(0, new LogEntry { Time = DateTime.Now.ToString("HH:mm:ss"), Message = msg, ColorClass = colorClass });
        if (_logs.Count > 100) _logs.RemoveAt(_logs.Count - 1);
        StateHasChanged();
    }
    
    private void ClearLogs()
    {
        _logs.Clear();
    }

    public class LogEntry
    {
        public string Time { get; set; } = "";
        public string Message { get; set; } = "";
        public string ColorClass { get; set; } = "";
    }
}
