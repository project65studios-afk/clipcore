@page "/admin/fulfillment"
@using Project65.Core.Entities
@using Project65.Core.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject IPurchaseRepository PurchaseRepository
@inject IClipRepository ClipRepository
@inject NavigationManager Navigation
@rendermode RenderMode.InteractiveServer

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">Order Fulfillment</h1>
        <div class="badge bg-primary">Admin Only</div>
    </div>

    <div class="card bg-dark border-secondary shadow">
        <div class="card-header border-secondary bg-dark">
            <h5 class="mb-0">Pending Deliveries</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0">
                    <thead class="table-secondary text-dark">
                        <tr>
                            <th>Order Date</th>
                            <th>Customer ID</th>
                            <th>Clip Title</th>
                            <th>Master Filename</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_pendingPurchases == null)
                        {
                            <tr><td colspan="5" class="text-center py-4">Loading...</td></tr>
                        }
                        else if (!_pendingPurchases.Any())
                        {
                            <tr><td colspan="5" class="text-center py-4 text-muted">No pending deliveries. You're all caught up!</td></tr>
                        }
                        else
                        {
                            @foreach (var p in _pendingPurchases)
                            {
                                <tr>
                                    <td>@p.CreatedAt.ToLocalTime().ToString("g")</td>
                                    <td><code class="text-info">@p.UserId.ToString().Substring(0, 8)...</code></td>
                                    <td>@p.Clip.Title</td>
                                    <td>
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-file-earmark-play-fill mr-1"></i>
                                            @(p.Clip.MasterFileName ?? "Unknown")
                                        </span>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-success" @onclick="() => OpenFulfillModal(p)">
                                            Fulfill Order
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@if (_showModal && _selectedPurchase != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.8);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary text-white">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">Fulfill: @_selectedPurchase.Clip.Title</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-secondary">Step 1: Locate Master File</label>
                        <div class="p-2 bg-black rounded border border-secondary mb-2">
                            <code>@(_selectedPurchase.Clip.MasterFileName ?? "No filename tracked")</code>
                        </div>
                        <small class="text-muted">Find this file on your local drive and upload it to a storage service (Mux, WeTransfer, S3, etc.)</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-secondary">Step 2: Provide Download Link</label>
                        <input class="form-control bg-dark text-white border-secondary" 
                               placeholder="https://..." @bind="_downloadUrl" />
                        <div class="form-text text-muted">The customer will see a download button with this link.</div>
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                    <button class="btn btn-outline-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveFulfillment" disabled="@(string.IsNullOrEmpty(_downloadUrl))">
                        Complete Fulfillment
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Purchase>? _pendingPurchases;
    private bool _showModal = false;
    private Purchase? _selectedPurchase;
    private string _downloadUrl = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadPendingAsync();
    }

    private async Task LoadPendingAsync()
    {
        var all = await PurchaseRepository.ListAsync();
        _pendingPurchases = all.Where(p => p.FulfillmentStatus == FulfillmentStatus.Pending)
                               .OrderByDescending(p => p.CreatedAt)
                               .ToList();
    }

    private void OpenFulfillModal(Purchase p)
    {
        _selectedPurchase = p;
        _downloadUrl = "";
        _showModal = true;
    }

    private void CloseModal()
    {
        _showModal = false;
        _selectedPurchase = null;
    }

    private async Task SaveFulfillment()
    {
        if (_selectedPurchase == null || string.IsNullOrEmpty(_downloadUrl)) return;

        _selectedPurchase.HighResDownloadUrl = _downloadUrl;
        _selectedPurchase.FulfillmentStatus = FulfillmentStatus.Fulfilled;
        _selectedPurchase.FulfilledAt = DateTime.UtcNow;

        await PurchaseRepository.UpdateAsync(_selectedPurchase);
        
        // TODO: Send Email Notification
        
        CloseModal();
        await LoadPendingAsync();
    }
}
