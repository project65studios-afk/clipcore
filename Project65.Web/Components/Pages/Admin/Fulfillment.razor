@page "/admin/fulfillment"
@using Project65.Core.Entities
@using Project65.Core.Interfaces
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject IPurchaseRepository PurchaseRepository
@inject IClipRepository ClipRepository
@inject NavigationManager Navigation
@inject IVideoService VideoService
@inject IJSRuntime JSRuntime
@inject IStorageService StorageService
@inject IEmailService EmailService
@rendermode RenderMode.InteractiveServer

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2 mb-0">Order Fulfillment</h1>
        <div class="badge bg-primary">Admin Only</div>
    </div>

    <div class="card border-0 shadow-sm" style="background: #f8f9fa;">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 text-dark">Delivery Queue</h5>
            <div class="btn-group shadow-sm">
                <button class="btn btn-sm @(_currentFilter == "Pending" ? "btn-warning text-white" : "btn-white text-secondary border")" 
                        @onclick='() => SetFilter("Pending")'>Pending</button>
                <button class="btn btn-sm @(_currentFilter == "Fulfilled" ? "btn-success" : "btn-white text-secondary border")" 
                        @onclick='() => SetFilter("Fulfilled")'>Fulfilled</button>
                <button class="btn btn-sm @(_currentFilter == "All" ? "btn-dark" : "btn-white text-secondary border")" 
                        @onclick='() => SetFilter("All")'>All</button>
            </div>
        </div>
        <div class="card-body p-0 bg-light">
                @if (_filteredPurchases == null)
                {
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                }
                else if (!_filteredPurchases.Any())
                {
                    <div class="text-center py-5 text-muted">No orders found matching this filter.</div>
                }
                else
                {
                    var groupedOrders = _filteredPurchases
                        .GroupBy(p => p.StripeSessionId)
                        .OrderByDescending(g => g.First().CreatedAt)
                        .ToList();

                    foreach (var order in groupedOrders)
                    {
                        var firstItem = order.First();
                        var orderId = !string.IsNullOrEmpty(firstItem.StripeSessionId) 
                            ? "ORD-" + firstItem.StripeSessionId.Substring(firstItem.StripeSessionId.Length - 8).ToUpper() 
                            : "LEGACY-" + firstItem.Id;

                        <div class="card border-0 shadow-sm mb-4 mx-3 mt-3 overflow-hidden rounded-3">
                             
                             <!-- Order Header -->
                             <div class="card-header bg-white p-3 border-bottom">
                                <div class="row align-items-center">
                                    <div class="col-md-4">
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="fw-bold fs-5 text-dark">@orderId</div>
                                            <span class="badge bg-light text-dark border">@order.Count() Items</span>
                                        </div>
                                        <div class="text-muted small">
                                            @firstItem.CreatedAt.ToLocalTime().ToString("MMMM dd, yyyy") at @firstItem.CreatedAt.ToLocalTime().ToString("t")
                                        </div>
                                    </div>
                                    <div class="col-md-8 text-md-end mt-2 mt-md-0">
                                        <div class="d-flex justify-content-md-end gap-3 text-start text-md-end align-items-center">
                                            
                                            <!-- Order Completion Logic -->
                                            @{
                                                var allFilesUploaded = order.All(p => p.Clip != null && !string.IsNullOrEmpty(p.Clip.MasterFileName));
                                                var isFullyFulfilled = order.All(p => p.FulfillmentStatus == FulfillmentStatus.Fulfilled);
                                            }

                                            @if (isFullyFulfilled)
                                            {
                                                <!-- Ready / Copy Link -->
                                                <div class="d-flex align-items-center gap-2 bg-light border rounded px-2 py-1">
                                                    <span class="badge bg-success small text-uppercase">Ready</span>
                                                    <div class="input-group input-group-sm" style="width: 260px;">
                                                        <input type="text" class="form-control bg-white font-monospace text-muted border-secondary" 
                                                               style="font-size: 0.8rem;"
                                                               readonly value="@($"{Navigation.BaseUri}delivery/{firstItem.StripeSessionId}")" 
                                                               onclick="this.select()" />
                                                        <button class="btn btn-outline-secondary" onclick="navigator.clipboard.writeText(this.previousElementSibling.value)" title="Copy Link">
                                                            <i class="bi bi-clipboard"></i>
                                                        </button>
                                                    </div>
                                                </div>
                                            }
                                            else if (allFilesUploaded)
                                            {
                                                <!-- Action Button -->
                                                <button class="btn btn-success btn-sm shadow-sm" @onclick="() => CompleteOrder(order.ToList())">
                                                    <i class="bi bi-send-check me-1"></i> Complete & Get Link
                                                </button>
                                            }
                                            else
                                            {
                                                <!-- Status -->
                                                <div class="text-warning small fw-bold bg-warning bg-opacity-10 px-2 py-1 rounded">
                                                    <i class="bi bi-hourglass-split me-1"></i> Upload Remaining Files
                                                </div>
                                            }

                                            <div class="vr mx-2 d-none d-md-block text-secondary"></div>

                                            <div>
                                                <div class="text-uppercase text-muted fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Customer</div>
                                                <div class="fw-bold text-dark">@(firstItem.CustomerName ?? "Anonymous")</div>
                                                <div class="small text-primary text-decoration-underline">@(firstItem.CustomerEmail ?? "No Email")</div>
                                                @if (!string.IsNullOrEmpty(firstItem.CustomerPhone))
                                                {
                                                    <div class="small text-dark mt-1"><i class="bi bi-telephone me-1"></i>@firstItem.CustomerPhone</div>
                                                }
                                            </div>
                                            @if (!string.IsNullOrEmpty(firstItem.CustomerAddress))
                                            {
                                                <div>
                                                    <div class="text-uppercase text-muted fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">Billing Address</div>
                                                    <div class="small text-dark" style="max-width: 250px; line-height: 1.2;">@firstItem.CustomerAddress</div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                             </div>

                             <!-- Items Table -->
                             <div class="table-responsive bg-white">
                                <table class="table table-hover mb-0 align-middle">
                                    <thead class="bg-light">
                                        <tr class="text-uppercase text-muted small border-bottom">
                                            <th class="ps-4 py-3" style="width: 35%;">Clip Info</th>
                                            <th style="width: 20%;">Event Details</th>
                                            <th style="width: 15%;">Price / Duration</th>
                                            <th style="width: 15%;">Status</th>
                                            <th class="text-end pe-4" style="width: 15%;">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var p in order)
                                        {
                                            <tr>
                                                <td class="ps-4">
                                                    <div class="fw-bold text-dark">@p.Clip.Title</div>
                                                    <div class="small text-muted font-monospace mt-1">
                                                        <i class="bi bi-file-earmark-film me-1"></i>
                                                        @(p.Clip.MasterFileName ?? "No Master File")
                                                    </div>
                                                </td>
                                                <td>
                                                    @if (p.Clip.Event != null)
                                                    {
                                                        <div class="text-dark">@p.Clip.Event.Name</div>
                                                        <div class="small text-secondary">@p.Clip.Event.Date.ToString("d")</div>
                                                    }
                                                    else
                                                    {
                                                        <span class="text-muted fst-italic">Unknown Event</span>
                                                    }
                                                </td>
                                                <td>
                                                    <div class="text-dark fw-bold">$@((p.PricePaidCents > 0 ? p.PricePaidCents : p.Clip.PriceCents) / 100.00)</div>
                                                    <div class="small text-muted">@((int)(p.Clip.DurationSec ?? 0)) seconds</div>
                                                </td>
                                                <td>
                                                    @if (p.FulfillmentStatus == FulfillmentStatus.Fulfilled)
                                                    {
                                                        <span class="badge bg-success text-white rounded-pill px-3">
                                                            <i class="bi bi-check-circle-fill me-1"></i> Fulfilled
                                                        </span>
                                                        @if (p.FulfilledAt.HasValue)
                                                        {
                                                            <div style="font-size: 0.7rem; color: #6c757d;" class="mt-1 ms-1">
                                                                @p.FulfilledAt.Value.ToLocalTime().ToString("MM/dd h:mm tt")
                                                            </div>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning text-dark rounded-pill px-3">
                                                            <i class="bi bi-clock me-1"></i> Pending
                                                        </span>
                                                    }
                                                </td>
                                                <td class="text-end pe-4">
                                                    @if (p.FulfillmentStatus == FulfillmentStatus.Pending) 
                                                    {
                                                        <button class="btn btn-sm btn-primary shadow-sm" @onclick="() => OpenFulfillModal(p)">
                                                            <i class="bi bi-upload me-1"></i> Fulfill
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button class="btn btn-sm btn-outline-secondary" @onclick="() => OpenFulfillModal(p)">
                                                            <i class="bi bi-pencil me-1"></i> Update
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                             </div>
                        </div>
                    }
                }
        </div>
    </div>
</div>

@if (_showModal && _selectedPurchase != null)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.8);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary text-white">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title">Fulfill: @_selectedPurchase.Clip.Title</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label text-secondary">Step 1: Locate Master File</label>
                        <div class="p-2 bg-black rounded border border-secondary mb-2">
                            <code>@(_selectedPurchase.Clip.MasterFileName ?? "No filename tracked")</code>
                        </div>
                        <small class="text-muted">Find this file on your local drive and upload it to a storage service (Mux, WeTransfer, S3, etc.)</small>
                    </div>
                    
                    <div class="mb-3">
                        <label class="form-label text-secondary">Step 2: Upload Master File (Safe & Private)</label>
                        
                        <!-- Uppy Container -->
                        <div id="fulfillment-uppy" style="background: #111; border-radius: 8px;"></div>
                        
                        @if (!string.IsNullOrEmpty(_uploadError))
                        {
                            <div class="alert alert-danger mt-2">@_uploadError</div>
                        }
                    </div>
                </div>
                <div class="modal-footer border-secondary">
                        <button class="btn btn-outline-secondary" @onclick="CloseModal">Close</button>
                </div>
            </div>
        </div>
    </div>
}

@inject IJSRuntime JSRuntime
@inject IVideoService VideoService

@code {
    private List<Purchase>? _allPurchases;
    private List<Purchase>? _filteredPurchases;
    private string _currentFilter = "Pending";
    
    private bool _showModal = false;
    private Purchase? _selectedPurchase;

    
    // Upload State
    private string _uploadError = "";
    private DotNetObjectReference<Fulfillment>? _objRef;

    protected override async Task OnInitializedAsync()
    {
        // Ensure CORS is set up for browser uploads
        await StorageService.ConfigureCorsAsync();
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        _allPurchases = await PurchaseRepository.ListAsync();
        ApplyFilter();
    }
    
    private void SetFilter(string filter)
    {
        _currentFilter = filter;
        ApplyFilter();
    }

    private void ApplyFilter()
    {
        if (_allPurchases == null) return;
        
        switch (_currentFilter)
        {
            case "Pending":
                _filteredPurchases = _allPurchases.Where(p => p.FulfillmentStatus == FulfillmentStatus.Pending).ToList();
                break;
            case "Fulfilled":
                _filteredPurchases = _allPurchases.Where(p => p.FulfillmentStatus == FulfillmentStatus.Fulfilled).ToList();
                break;
            default:
                _filteredPurchases = _allPurchases.ToList();
                break;
        }
    }

    private IJSObjectReference? _jsUppy;

    // Called by UI button
    private async Task OpenFulfillModal(Purchase p)
    {
        _selectedPurchase = p;
        _uploadError = "";
        _showModal = true;
        StateHasChanged();
        
        // Initialize Uppy after render
        await Task.Delay(100); 
        _objRef = DotNetObjectReference.Create(this);
        // We might want to store the JS reference to dispose later
        _jsUppy = await JSRuntime.InvokeAsync<IJSObjectReference>("fulfillmentUpload.initUppy", _objRef, "fulfillment-uppy");
    }

    private void CloseModal()
    {
        _showModal = false;
        _selectedPurchase = null;
    }

    [JSInvokable]
    public Task<string> GetR2UploadUrl(string fileName, string contentType)
    {
        if (_selectedPurchase == null) return Task.FromResult("");
        
        // Generate R2 Key: purchase-id/filename
        var key = $"{_selectedPurchase.Id}/{fileName}";
        _pendingMasterFileName = key; // Track what to save
        
        var url = StorageService.GetPresignedUploadUrl(key, contentType);
        return Task.FromResult(url);
    }

    private string? _pendingMasterFileName;

    [JSInvokable]
    public async Task OnUploadSuccess()
    {
        if (_selectedPurchase != null && !string.IsNullOrEmpty(_pendingMasterFileName))
        {
             // 1. Update CLIP (Fetch first to avoid tracking conflict)
             if (_selectedPurchase.Clip != null)
             {
                 var trackedClip = await ClipRepository.GetByIdAsync(_selectedPurchase.Clip.Id);
                 if (trackedClip != null)
                 {
                     trackedClip.MasterFileName = _pendingMasterFileName;
                     await ClipRepository.UpdateAsync(trackedClip);
                     
                     // Update local state to reflect change in UI instantly
                     _selectedPurchase.Clip.MasterFileName = _pendingMasterFileName;
                 }
             }

             // 2. Update PURCHASE (Repo handles fetching internally)
             _selectedPurchase.FulfillmentStatus = FulfillmentStatus.Fulfilled;
             _selectedPurchase.FulfilledAt = DateTime.UtcNow;
             await PurchaseRepository.UpdateAsync(_selectedPurchase);
                 
             CloseModal();
             await LoadDataAsync();
        }
        StateHasChanged();
    }

    [JSInvokable]
    public void OnUploadError(string msg)
    {
        _uploadError = "Upload failed: " + msg;
        StateHasChanged();
    }
    
    // --- New Order Logic ---
    private async Task CompleteOrder(List<Purchase> order)
    {
        var firstItem = order.First();
        var customerEmail = firstItem.CustomerEmail;
        var deliveryLink = $"{Navigation.BaseUri}delivery/{firstItem.StripeSessionId}";
        
        foreach (var p in order)
        {
            if (p.FulfillmentStatus == FulfillmentStatus.Pending)
            {
                p.FulfillmentStatus = FulfillmentStatus.Fulfilled;
                p.FulfilledAt = DateTime.UtcNow;
                // Save the dynamic link as the fallback
                p.HighResDownloadUrl = deliveryLink;
                await PurchaseRepository.UpdateAsync(p);
            }
        }

        // Send Email Notification
        if (!string.IsNullOrEmpty(customerEmail))
        {
            try 
            {
                var body = $@"
                    <h2>Your Order is Ready! 📦</h2>
                    <p>Good news! Your video clips are ready for download.</p>
                    <p><strong>Order ID:</strong> {(!string.IsNullOrEmpty(firstItem.StripeSessionId) ? firstItem.StripeSessionId.Substring(firstItem.StripeSessionId.Length - 8).ToUpper() : "N/A")}</p>
                    <br/>
                    <a href='{deliveryLink}' style='background: #007bff; color: white; padding: 12px 24px; text-decoration: none; border-radius: 4px; display: inline-block;'>Download Files</a>
                    <br/><br/>
                    <small>If the button doesn't work, copy this link: {deliveryLink}</small>
                ";

                await EmailService.SendEmailAsync(customerEmail, "Your Order is Ready! 📦", body);
                // Ideally show toast/notification of email success
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Email Error] Failed to send fulfillment email: {ex.Message}");
                // Proceed anyway, don't block fulfillment state
            }
        }

        // Switch to "Fulfilled" tab to show the result
        _currentFilter = "Fulfilled";
        await LoadDataAsync();
    }

    public async ValueTask DisposeAsync()
    {
        _objRef?.Dispose();
        if (_jsUppy != null)
        {
            await _jsUppy.InvokeVoidAsync("dispose");
            await _jsUppy.DisposeAsync();
        }
    }
}
