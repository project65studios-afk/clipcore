@page "/search"
@using Project65.Core.Entities
@using Project65.Core.Interfaces
@inject IEventRepository EventRepository
@inject IClipRepository ClipRepository
@inject IVideoService VideoService
@inject ISettingsRepository SettingsRepository
@inject IStorageService StorageService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject Project65.Web.Services.CartService CartService
@inject IWebHostEnvironment Environment
@using System.IO
@implements IDisposable
@rendermode RenderMode.InteractiveServer

<PageTitle>Search Results - Project65</PageTitle>

<div class="content-container" style="max-width: 1200px; margin: 0 auto; padding: 2rem 1rem;">
    <div class="mb-4">
        <h1 class="h2">Search Results</h1>
        @if (!string.IsNullOrWhiteSpace(Query))
        {
            <p class="text-muted">Showing results for <span class="text-white fw-bold">"@Query"</span></p>
        }
    </div>

    @if (_isSearching)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Searching...</p>
        </div>
    }
    else if (_events.Count == 0 && _clips.Count == 0)
    {
        <div class="text-center py-5" style="background: var(--bg-dark-800); border-radius: var(--radius-lg); border: 1px dashed var(--border-color);">
            <i class="bi bi-search display-1 text-muted opacity-25"></i>
            <h3 class="mt-3 text-white">No results found</h3>
            <p class="text-secondary">Try adjusting your search terms or check your spelling.</p>
            <a href="/" class="btn btn-outline-primary mt-2">Browse All Events</a>
        </div>
    }
    else
    {
        @if (_events.Any())
        {
            <div class="mb-5">
                <h3 class="h4 mb-3 border-bottom border-secondary pb-2">Events (@_events.Count)</h3>
                <div class="row g-4">
                    @foreach (var evt in _events)
                    {
                        <div class="col-md-6 col-lg-4">
                            <a href="/events/@evt.Id" class="card h-100 text-decoration-none border-0 shadow-sm event-card" style="background: var(--bg-dark-800); transition: transform 0.2s;">
                                <div class="card-body">
                                    <h5 class="card-title text-white mb-1">@evt.Name</h5>
                                    <div class="text-muted small mb-3">@evt.Date.ToString("MMMM dd, yyyy")</div>
                                    @if (!string.IsNullOrEmpty(evt.Summary))
                                    {
                                        <div class="text-secondary small text-truncate">@evt.Summary</div>
                                    }
                                    <div class="mt-2 badge bg-secondary bg-opacity-25 text-secondary border border-secondary border-opacity-25">
                                        @evt.Clips.Count Clips
                                    </div>
                                </div>
                            </a>
                        </div>
                    }
                </div>
            </div>
        }

        @if (_clips.Any())
        {
            <div>
                <h3 class="h4 mb-3 border-bottom border-secondary pb-2">Clips (@_clips.Count)</h3>
                <div class="video-grid">
                    @foreach (var clip in _clips)
                    {
                        <div @key="clip.Id" @onclick="() => NavigateToClip(clip.Id)" class="video-card" data-enhance-nav="false">
                            <div class="video-thumb">
                                @if (IsInCart(clip.Id))
                                {
                                    <button class="btn-quick-add added" @onclick:stopPropagation="true" @onclick="() => ToggleCart(clip)">
                                        <i class="bi bi-dash-lg"></i>
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-quick-add" @onclick:stopPropagation="true" @onclick="() => ToggleCart(clip)">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                }

                                @if (clip.PlaybackIdTeaser?.StartsWith("mock") == true)
                                {
                                     <div style="width: 100%; height: 100%; background: linear-gradient(45deg, #1e293b, #0f172a); display: flex; align-items: center; justify-content: center; color: var(--text-muted);">
                                         <span>Mock Video</span>
                                     </div>
                                }
                                else if (!string.IsNullOrEmpty(clip.ThumbnailFileName))
                                {
                                     var thumbUrl = GetHybridThumbnailUrl(clip);
                                     <img src="@thumbUrl" 
                                          alt="@clip.Title" 
                                          style="width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: 4px;" />
                                }
                                else if (string.IsNullOrEmpty(GetThumbnailId(clip)))
                                {
                                     <div style="width: 100%; height: 100%; background: #0f172a; display: flex; align-items: center; justify-content: center; color: var(--text-muted); border-radius: 4px;">
                                         <div class="text-center">
                                             <div class="spinner-border spinner-border-sm mb-2" role="status"></div>
                                             <div style="font-size: 0.7rem;">Processing...</div>
                                         </div>
                                     </div>
                                }
                                else
                                {
                                    <img src="https://image.mux.com/@GetThumbnailId(clip)/thumbnail.jpg?token=@GetToken(clip)" 
                                         alt="@clip.Title" 
                                         style="width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: 4px;" />
                                }
                                
                                @{
                                     var pid = string.IsNullOrEmpty(clip.PlaybackIdTeaser) ? clip.PlaybackIdSigned : clip.PlaybackIdTeaser;
                                }
                                @if (!string.IsNullOrEmpty(pid) && !pid.StartsWith("mock"))
                                {
                                     <div id="preview-container-@clip.Id" class="video-player-container preview-player">
                                         @if (!string.IsNullOrEmpty(_watermarkUrl))
                                         {
                                             <div class="watermark-grid" style="--wm-url: url('@_watermarkUrl');">
                                                 @for (int i = 0; i < 36; i++)
                                                 {
                                                     int row = i / 6;
                                                     int col = i % 6;
                                                     bool isActive = (row + col) % 2 == 0;
                                                     <div class="watermark-cell @(isActive ? "active" : "")"></div>
                                                 }
                                             </div>
                                         }

                                         @if (HasTokens(pid))
                                         {
                                             <mux-player
                                               playback-id="@pid"
                                               playback-token="@GetTokenFromCache(pid, "v")"
                                               thumbnail-token="@GetTokenFromCache(pid, "t")"
                                               storyboard-token="@GetTokenFromCache(pid, "s")"
                                               metadata-video-title="@clip.Title"
                                               muted
                                               autoplay
                                               loop
                                               fullscreen-element="preview-container-@clip.Id"
                                               style="width: 100%; height: 100%; object-fit: cover;"
                                               controls="false"
                                             ></mux-player>
                                         }
                                         else
                                         {
                                              <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #000;">
                                                  <div class="spinner-border spinner-border-sm text-info" role="status"></div>
                                              </div>
                                         }
                                     </div>
                                }
                            </div>
                                
                            @if (!string.IsNullOrEmpty(clip.TagsJson) && clip.TagsJson != "[]")
                            {
                                <div style="display: flex; gap: 0.25rem; margin-top: 0.4rem; overflow: hidden; flex-wrap: wrap; height: 1.25rem;">
                                    @{
                                        var tags = System.Text.Json.JsonSerializer.Deserialize<string[]>(clip.TagsJson) ?? Array.Empty<string>();
                                    }
                                    @foreach (var tag in tags.Take(3))
                                    {
                                        <a href="/search?q=@tag" @onclick:stopPropagation="true" class="badge text-decoration-none" style="background: var(--bg-dark-900); color: var(--text-secondary); border: 1px solid var(--border-color); font-weight: 500; font-size: 0.65rem; padding: 0.15rem 0.4rem;">
                                            @tag
                                        </a>
                                    }
                                </div>
                            }
                            <div class="video-info">
                                <div style="flex-grow: 1; min-width: 0;">
                                    <div style="font-weight: 600; font-size: 1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@clip.Title">@clip.Title</div>
                                     <div style="font-size: 0.85rem; color: var(--accent-cyan); margin-top: 0.1rem; font-weight: 500; display: flex; gap: 0.5rem; align-items: center;">
                                         @if (clip.RecordingStartedAt.HasValue)
                                         {
                                             <span style="color: var(--text-secondary);">@clip.RecordingStartedAt.Value.ToString("MMM dd, h:mm tt")</span>
                                             <span style="color: var(--text-muted); font-size: 0.7rem; margin: 0 0.3rem;">•</span>
                                         }
                                         @if (clip.DurationSec.HasValue)
                                         {
                                             <span>@TimeSpan.FromSeconds(clip.DurationSec.Value).ToString(@"mm\:ss")</span>
                                         }
                                     </div>
                                </div>
                                <span class="price-tag" style="align-self: flex-start; margin-top: 0.2rem;">$@(clip.PriceCents / 100.00)</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "q")]
    public string? Query { get; set; }

    private List<Event> _events = new();
    private List<Clip> _clips = new();
    private bool _isSearching = false;
    private string? _watermarkUrl;
    private Dictionary<string, string> _tokenCache = new();
    private HashSet<string> _cartItemIds = new();

    protected override async Task OnInitializedAsync()
    {
        _watermarkUrl = await SettingsRepository.GetValueAsync("WatermarkUrl");
        CartService.OnChange += OnCartChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (string.IsNullOrWhiteSpace(Query))
        {
            _events.Clear();
            _clips.Clear();
            return;
        }

        _isSearching = true;
        StateHasChanged();

        try
        {
            var eventsTask = EventRepository.SearchAsync(Query);
            var clipsTask = ClipRepository.SearchAsync(Query);

            await Task.WhenAll(eventsTask, clipsTask);

            _events = await eventsTask;
            _clips = await clipsTask;

            if (_clips != null)
            {
                // Identifiy clips needing repair
                var brokenClips = _clips.Where(c => 
                    (string.IsNullOrEmpty(c.PlaybackIdSigned) && string.IsNullOrEmpty(c.PlaybackIdTeaser) && !string.IsNullOrEmpty(c.MuxUploadId))
                ).ToList();

                foreach (var clip in brokenClips)
                {
                    await TryRepairClipAsync(clip);
                }

                foreach (var clip in _clips)
                {
                    var pid = string.IsNullOrEmpty(clip.PlaybackIdTeaser) ? clip.PlaybackIdSigned : clip.PlaybackIdTeaser;
                    if (!string.IsNullOrEmpty(pid) && !pid.StartsWith("mock"))
                    {
                        await LoadTokensForClip(pid);
                    }
                    else if (pid == null)
                    {
                        await JSRuntime.InvokeVoidAsync("console.warn", $"[Search] Clip {clip.Title} has no playback ID.");
                    }
                }
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Search error: {ex}");
        }
        finally
        {
            _isSearching = false;
        }
    }

    private async Task TryRepairClipAsync(Clip clip)
    {
        try
        {
            bool needsUpdate = false;
            if (string.IsNullOrEmpty(clip.MuxAssetId) && !string.IsNullOrEmpty(clip.MuxUploadId))
            {
                var assetId = await VideoService.GetAssetIdFromUploadAsync(clip.MuxUploadId!);
                if (!string.IsNullOrEmpty(assetId)) { clip.MuxAssetId = assetId; needsUpdate = true; }
            }

            if (!string.IsNullOrEmpty(clip.MuxAssetId) && string.IsNullOrEmpty(clip.PlaybackIdSigned))
            {
                var newId = await VideoService.EnsurePlaybackIdAsync(clip.MuxAssetId);
                if (!string.IsNullOrEmpty(newId)) { clip.PlaybackIdSigned = newId; needsUpdate = true; }
            }

            if (needsUpdate)
            {
                using var scope = ScopeFactory.CreateScope();
                var repo = scope.ServiceProvider.GetRequiredService<IClipRepository>();
                await repo.UpdateAsync(clip);
                await JSRuntime.InvokeVoidAsync("console.log", $"[Search] Healed clip: {clip.Title}");
            }
        }
        catch (Exception ex)
        {
             Console.WriteLine($"[Search] Repair failed: {ex.Message}");
        }
    }

    [Inject] 
    private IServiceScopeFactory ScopeFactory { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await CartService.InitializeAsync();
            UpdateCartState();
            StateHasChanged();
        }
    }

    private void NavigateToClip(string clipId)
    {
        Navigation.NavigateTo($"/clips/{clipId}");
    }

    private bool IsInCart(string clipId)
    {
        return _cartItemIds.Contains(clipId);
    }

    private async Task ToggleCart(Clip clip)
    {
        if (IsInCart(clip.Id))
        {
            await CartService.RemoveAsync(clip.Id);
            _cartItemIds.Remove(clip.Id);
        }
        else
        {
            var item = new Project65.Web.Models.CartItem
            {
                Id = clip.Id,
                Title = clip.Title,
                PriceCents = clip.PriceCents,
                DurationSec = clip.DurationSec,
                PlaybackId = clip.PlaybackIdSigned,
                EventId = clip.EventId
            };
            await CartService.AddAsync(item);
            _cartItemIds.Add(clip.Id);
        }
    }

    private void OnCartChanged()
    {
        UpdateCartState();
        StateHasChanged();
    }

    private void UpdateCartState()
    {
        _cartItemIds = CartService.GetItems().Select(i => i.Id).ToHashSet();
    }

    private async Task LoadTokensForClip(string playbackId)
    {
        bool tokensAdded = false;
        
        if (!_tokenCache.ContainsKey($"{playbackId}-v"))
        {
            var token = await VideoService.GetPlaybackToken(playbackId, "v", "480p");
            if (!string.IsNullOrEmpty(token)) { _tokenCache[$"{playbackId}-v"] = token; tokensAdded = true; }
        }
            
        if (!_tokenCache.ContainsKey($"{playbackId}-t"))
        {
            var token = await VideoService.GetPlaybackToken(playbackId, "t", "480p");
            if (!string.IsNullOrEmpty(token)) { _tokenCache[$"{playbackId}-t"] = token; tokensAdded = true; }
        }

        if (!_tokenCache.ContainsKey($"{playbackId}-s"))
        {
            var token = await VideoService.GetPlaybackToken(playbackId, "s", "480p");
            if (!string.IsNullOrEmpty(token)) { _tokenCache[$"{playbackId}-s"] = token; tokensAdded = true; }
        }

        if (tokensAdded)
        {
            StateHasChanged();
        }
    }

    private string GetHybridThumbnailUrl(Clip clip)
    {
        if (string.IsNullOrEmpty(clip.ThumbnailFileName)) return "";

        var localPath = Path.Combine(Environment.WebRootPath, "thumbnails", clip.ThumbnailFileName);
        if (File.Exists(localPath))
        {
            return $"/thumbnails/{clip.ThumbnailFileName}";
        }
        
        return StorageService.GetPresignedDownloadUrl($"thumbnails/{clip.ThumbnailFileName}");
    }

    private string GetThumbnailId(Clip clip)
    {
        return clip.PlaybackIdTeaser ?? clip.PlaybackIdSigned;
    }

    private string GetToken(Clip clip)
    {
        var id = GetThumbnailId(clip);
        return GetTokenFromCache(id, "t");
    }
    
    private string GetTokenFromCache(string playbackId, string type)
    {
        return _tokenCache.TryGetValue($"{playbackId}-{type}", out var token) ? token : "";
    }

    private bool HasTokens(string playbackId)
    {
        return _tokenCache.TryGetValue($"{playbackId}-v", out var v) && !string.IsNullOrEmpty(v) && 
               _tokenCache.TryGetValue($"{playbackId}-t", out var t) && !string.IsNullOrEmpty(t) && 
               _tokenCache.TryGetValue($"{playbackId}-s", out var s) && !string.IsNullOrEmpty(s);
    }

    public void Dispose()
    {
        CartService.OnChange -= OnCartChanged;
    }
}
```
