@page "/events/{Id}"
@using Project65.Core.Entities
@using Project65.Core.Interfaces
@inject IEventRepository EventRepository
@inject IVideoService VideoService
@inject ISettingsRepository SettingsRepository
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>@_event?.Name - Project65</PageTitle>

@if (_event == null)
{
    @if (_loading) { <p>Loading...</p> }
    else { <p>Event not found.</p> }
}
else
{
    <div class="mb-4">
        <a href="/" style="color: var(--text-secondary); font-size: 0.9rem;">← Back to Events</a>
    </div>

    <div style="background: var(--bg-dark-800); border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 3rem; border: 1px solid var(--border-color);">
        <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">@_event.Name</h1>
        <div style="display: flex; gap: 1rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
            <span>@_event.Date.ToLongDateString()</span>
            <span>•</span>
            <span>@_event.Clips.Count clips</span>
        </div>
        <p style="max-width: 600px; color: var(--text-secondary);">@_event.Summary</p>
        
        <div class="event-header-actions" style="margin-top: 1.5rem; display: flex; gap: 0.5rem; align-items: center;">
             <button class="btn-primary" @onclick="ShareEventAsync">Share Event</button>
             <button class="btn-secondary" @onclick="CopyLinkAsync">
                 @(_showCopiedMessage ? "Link Copied!" : "Copy Link")
             </button>
        </div>
    </div>
    
    <div class="mb-4 event-details-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3 class="section-title">All Clips</h3>
        <select class="form-control" style="width: auto;" @onchange="OnSortChanged" value="@_sortBy">
            <option value="TimeUsedAsc">Time Used: Oldest First</option>
            <option value="TimeUsedDesc">Time Used: Newest First</option>
            <option value="PriceLowHigh">Price: Low to High</option>
            <option value="PriceHighLow">Price: High to Low</option>
            <option value="DurationShortLong">Duration: Shortest First</option>
            <option value="DurationLongShort">Duration: Longest First</option>
        </select>
    </div>

    @if (!_event.Clips.Any())
    {
        <p>No clips available yet.</p>
    }
    else
    {
        <div class="video-grid">
            @foreach (var clip in _event.Clips)
            {
                <a href="/clips/@clip.Id" class="video-card" data-enhance-nav="false">
                    <div class="video-thumb">
                        @if (clip.PlaybackIdTeaser?.StartsWith("mock") == true)
                        {
                             <div style="width: 100%; height: 100%; background: linear-gradient(45deg, #1e293b, #0f172a); display: flex; align-items: center; justify-content: center; color: var(--text-muted);">
                                 <span>Mock Video</span>
                             </div>
                        }
                        else if (string.IsNullOrEmpty(GetThumbnailId(clip)))
                        {
                             <div style="width: 100%; height: 100%; background: #0f172a; display: flex; align-items: center; justify-content: center; color: var(--text-muted); border-radius: 4px;">
                                 <div class="text-center">
                                     <div class="spinner-border spinner-border-sm mb-2" role="status"></div>
                                     <div style="font-size: 0.7rem;">Processing...</div>
                                 </div>
                             </div>
                        }
                        else
                        {
                            <!-- Static Image (Thumbnail) - Use Signed URL if needed -->
                            <img src="https://image.mux.com/@GetThumbnailId(clip)/thumbnail.jpg?token=@GetToken(clip)" 
                                 alt="@clip.Title" 
                                 style="width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: 4px; border: 1px solid rgba(255,255,255,0.1);" />
                        }
                        
                        <!-- Hover Preview -->
                         @{
                             var previewId = clip.PlaybackIdTeaser ?? clip.PlaybackIdSigned;
                         }
                         @if (!string.IsNullOrEmpty(previewId) && !previewId.StartsWith("mock"))
                         {
                              <div id="preview-container-@clip.Id" class="video-player-container preview-player">
                                  @if (!string.IsNullOrEmpty(_watermarkUrl))
                                  {
                                      <div class="watermark-overlay">
                                          <img src="@_watermarkUrl" alt="Watermark" />
                                      </div>
                                  }

                                  <mux-player
                                    playback-id="@previewId"
                                    playback-token="@GetTokenFromCache(previewId, "v")"
                                    thumbnail-token="@GetTokenFromCache(previewId, "t")"
                                    storyboard-token="@GetTokenFromCache(previewId, "s")"
                                    metadata-video-title="@clip.Title"
                                    muted
                                    autoplay
                                    loop
                                    fullscreen-element="preview-container-@clip.Id"
                                    style="width: 100%; height: 100%; object-fit: cover;"
                                    controls="false"
                                  ></mux-player>
                              </div>
                         }
                    </div>
                    <div class="video-info">
                        <div style="flex-grow: 1; min-width: 0;">
                            <div style="font-weight: 600; font-size: 1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@clip.Title">@clip.Title</div>
                             <div style="font-size: 0.85rem; color: var(--accent-cyan); margin-top: 0.1rem; font-weight: 500; display: flex; gap: 0.5rem; align-items: center;">
                                 @if (clip.RecordingStartedAt.HasValue)
                                 {
                                     <span style="color: var(--text-secondary);">@clip.RecordingStartedAt.Value.ToString("MMM dd, h:mm tt")</span>
                                     <span style="color: var(--text-muted); font-size: 0.7rem;">•</span>
                                 }
                                 @if (clip.DurationSec.HasValue)
                                 {
                                     <span>@TimeSpan.FromSeconds(clip.DurationSec.Value).ToString(@"mm\:ss")</span>
                                 }
                                 else if (!clip.RecordingStartedAt.HasValue)
                                 {
                                     <span style="color: var(--text-muted); font-style: italic;">Processing...</span>
                                 }
                             </div>
                        </div>
                        <span class="price-tag" style="align-self: flex-start; margin-top: 0.2rem;">$@(clip.PriceCents / 100.00)</span>
                    </div>
                </a>
            }
        </div>
    }
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Event? _event;
    private bool _loading = true;
    private string? _watermarkUrl;
    private string _sortBy = "TimeUsedAsc"; // Default sort
    private Dictionary<string, string> _tokenCache = new();
    private bool _showCopiedMessage = false;

    private async Task CopyLinkAsync()
    {
        var uri = Navigation.Uri;
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", uri);
        _showCopiedMessage = true;
        StateHasChanged();
        await Task.Delay(2000);
        _showCopiedMessage = false;
        StateHasChanged();
    }

    private async Task ShareEventAsync()
    {
        var uri = Navigation.Uri;
        try 
        {
            await JSRuntime.InvokeVoidAsync("navigator.share", new { title = _event?.Name ?? "Project65 Event", url = uri });
        }
        catch 
        {
            // Fallback to copy link if share not supported or cancelled
            await CopyLinkAsync();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _watermarkUrl = await SettingsRepository.GetValueAsync("WatermarkUrl");
        _event = await EventRepository.GetByIdAsync(Id);
        
        if (_event?.Clips != null)
        {
            SortClips(); // Initial sort
            
            // Pre-load tokens asynchronously
            foreach (var clip in _event.Clips)
            {
                var pid = clip.PlaybackIdTeaser ?? clip.PlaybackIdSigned;
                if (!string.IsNullOrEmpty(pid) && !pid.StartsWith("mock"))
                {
                    await LoadTokensForClip(pid);
                }
            }
        }
        
        _loading = false;
    }

    private async Task LoadTokensForClip(string playbackId)
    {
        // Video Token (v)
        if (!_tokenCache.ContainsKey($"{playbackId}-v"))
            _tokenCache[$"{playbackId}-v"] = await VideoService.GetPlaybackToken(playbackId, "v", "480p");
            
        // Thumbnail Token (t)
        if (!_tokenCache.ContainsKey($"{playbackId}-t"))
            _tokenCache[$"{playbackId}-t"] = await VideoService.GetPlaybackToken(playbackId, "t", "480p");

        // Storyboard Token (s)
        if (!_tokenCache.ContainsKey($"{playbackId}-s"))
            _tokenCache[$"{playbackId}-s"] = await VideoService.GetPlaybackToken(playbackId, "s", "480p");
    }

    private void OnSortChanged(ChangeEventArgs e)
    {
        _sortBy = e.Value?.ToString() ?? "TimeUsedAsc";
        SortClips();
    }

    private void SortClips()
    {
        if (_event?.Clips == null || !_event.Clips.Any()) return;

        switch (_sortBy)
        {
            case "TimeUsedAsc": // Default: Least to greatest time used
                _event.Clips = _event.Clips.OrderBy(c => c.RecordingStartedAt ?? DateTime.MaxValue).ToList();
                break;
            case "TimeUsedDesc":
                _event.Clips = _event.Clips.OrderByDescending(c => c.RecordingStartedAt ?? DateTime.MinValue).ToList();
                break;
            case "PriceLowHigh":
                _event.Clips = _event.Clips.OrderBy(c => c.PriceCents).ToList();
                break;
            case "PriceHighLow":
                _event.Clips = _event.Clips.OrderByDescending(c => c.PriceCents).ToList();
                break;
            case "DurationShortLong":
                _event.Clips = _event.Clips.OrderBy(c => c.DurationSec ?? double.MaxValue).ToList();
                break;
            case "DurationLongShort":
                _event.Clips = _event.Clips.OrderByDescending(c => c.DurationSec ?? double.MinValue).ToList();
                break;
            default:
                _event.Clips = _event.Clips.OrderBy(c => c.RecordingStartedAt ?? DateTime.MaxValue).ToList();
                break;
        }
    }

    private string GetThumbnailId(Clip clip)
    {
        return clip.PlaybackIdTeaser ?? clip.PlaybackIdSigned;
    }

    private string GetToken(Clip clip)
    {
        // This is only used for the static img src tag, which is rendered synchronously.
        // We can grab it from cache if available, or empty.
        var id = GetThumbnailId(clip);
        return GetTokenFromCache(id, "t");
    }
    
    private string GetTokenFromCache(string playbackId, string type)
    {
        return _tokenCache.TryGetValue($"{playbackId}-{type}", out var token) ? token : "";
    }
}
