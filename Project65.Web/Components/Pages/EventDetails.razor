@page "/events/{Id}"
@using Project65.Core.Interfaces
@using Project65.Core.Entities
@inject IEventRepository EventRepository
@inject IVideoService VideoService
@inject ISettingsRepository SettingsRepository
@inject IStorageService StorageService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject Project65.Web.Services.CartService CartService
@inject IWebHostEnvironment Environment
@using System.IO
@implements IDisposable

<PageTitle>@_event?.Name - Project65</PageTitle>

@if (_event == null)
{
    @if (_loading) { <p>Loading...</p> }
    else { <p>Event not found.</p> }
}
else
{
    <div class="mb-4">
        <a href="/" style="color: var(--text-secondary); font-size: 0.9rem;">← Back to Events</a>
    </div>

    <div style="background: var(--bg-dark-800); border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 3rem; border: 1px solid var(--border-color);">
        <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">@_event.Name</h1>
        <div style="display: flex; gap: 1rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
            <span>@_event.Date.ToLongDateString()</span>
            <span>•</span>
            <span>@_event.Clips.Count clips</span>
        </div>
        <p style="max-width: 600px; color: var(--text-secondary);">@_event.Summary</p>
        
        <div class="event-header-actions" style="margin-top: 1.5rem; display: flex; gap: 0.5rem; align-items: center;">
             <button class="btn-primary" @onclick="ShareEventAsync">Share Event</button>
             <button class="btn-secondary" @onclick="CopyLinkAsync">
                 @(_showCopiedMessage ? "Link Copied!" : "Copy Link")
             </button>
        </div>
    </div>
    
    <div class="mb-4 event-details-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3 class="section-title">All Clips</h3>
        <select class="form-control" style="width: auto;" @onchange="OnSortChanged" value="@_sortBy">
            <option value="TimeUsedAsc">Time Used: Oldest First</option>
            <option value="TimeUsedDesc">Time Used: Newest First</option>
            <option value="PriceLowHigh">Price: Low to High</option>
            <option value="PriceHighLow">Price: High to Low</option>
            <option value="DurationShortLong">Duration: Shortest First</option>
            <option value="DurationLongShort">Duration: Longest First</option>
        </select>
    </div>

    @if (!_event.Clips.Any())
    {
        <p>No clips available yet.</p>
    }
    else
    {
        <div class="video-grid">
            @foreach (var clip in _event.Clips)
            {
                <div @key="clip.Id" @onclick="() => NavigateToClip(clip.Id)" class="video-card" data-enhance-nav="false">
                    <div class="video-thumb">
                        @if (IsInCart(clip.Id))
                        {
                            <button class="btn-quick-add added" @onclick:stopPropagation="true" @onclick="() => ToggleCart(clip)">
                                <i class="bi bi-dash-lg"></i>
                            </button>
                        }
                        else
                        {
                            <button class="btn-quick-add" @onclick:stopPropagation="true" @onclick="() => ToggleCart(clip)">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        }

                        @if (clip.PlaybackIdTeaser?.StartsWith("mock") == true)
                        {
                             <div style="width: 100%; height: 100%; background: linear-gradient(45deg, #1e293b, #0f172a); display: flex; align-items: center; justify-content: center; color: var(--text-muted);">
                                 <span>Mock Video</span>
                             </div>
                        }
                        else if (!string.IsNullOrEmpty(clip.ThumbnailFileName))
                        {
                             var thumbUrl = GetHybridThumbnailUrl(clip);
                             <!-- Local High-Res Thumbnail (Immediate & High Quality) -->
                             <img src="@thumbUrl" 
                                  alt="@clip.Title" 
                                  style="width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: 4px;" />
                        }
                        else if (string.IsNullOrEmpty(GetThumbnailId(clip)))
                        {
                             <div style="width: 100%; height: 100%; background: #0f172a; display: flex; align-items: center; justify-content: center; color: var(--text-muted); border-radius: 4px;">
                                 <div class="text-center">
                                     <div class="spinner-border spinner-border-sm mb-2" role="status"></div>
                                     <div style="font-size: 0.7rem;">Processing...</div>
                                 </div>
                             </div>
                        }
                        else
                        {
                            <!-- Fallback to Mux Thumbnail -->
                            <img src="https://image.mux.com/@GetThumbnailId(clip)/thumbnail.jpg?token=@GetToken(clip)" 
                                 alt="@clip.Title" 
                                 style="width: 100%; aspect-ratio: 16/9; object-fit: cover; border-radius: 4px;" />
                        }
                        
                        <!-- Hover Preview -->
                          @{
                              var previewId = string.IsNullOrEmpty(clip.PlaybackIdTeaser) ? clip.PlaybackIdSigned : clip.PlaybackIdTeaser;
                          }
                          @if (!string.IsNullOrEmpty(previewId) && !previewId.StartsWith("mock"))
                          {
                               <div id="preview-container-@clip.Id" class="video-player-container preview-player">
                                   @if (!string.IsNullOrEmpty(_watermarkUrl))
                                   {
                                       <div class="watermark-grid" style="--wm-url: url('@_watermarkUrl');">
                                           @for (int i = 0; i < 36; i++)
                                           {
                                               int row = i / 6;
                                               int col = i % 6;
                                               bool isActive = (row + col) % 2 == 0;
                                               <div class="watermark-cell @(isActive ? "active" : "")"></div>
                                           }
                                       </div>
                                   }

                                   @if (HasTokens(previewId))
                                   {
                                       <mux-player
                                         playback-id="@previewId"
                                         playback-token="@GetTokenFromCache(previewId, "v")"
                                         thumbnail-token="@GetTokenFromCache(previewId, "t")"
                                         storyboard-token="@GetTokenFromCache(previewId, "s")"
                                         metadata-video-title="@clip.Title"
                                         muted
                                         autoplay
                                         loop
                                         fullscreen-element="preview-container-@clip.Id"
                                         style="width: 100%; height: 100%; object-fit: cover;"
                                         controls="false"
                                       ></mux-player>
                                   }
                                   else
                                   {
                                        <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #000;">
                                            <div class="spinner-border spinner-border-sm text-info" role="status"></div>
                                        </div>
                                   }
                               </div>
                          }
                    </div>
                        
                         @if (!string.IsNullOrEmpty(clip.TagsJson) && clip.TagsJson != "[]")
                         {
                             <div style="display: flex; gap: 0.25rem; margin-top: 0.4rem; overflow: hidden; flex-wrap: wrap; height: 1.25rem;">
                                 @{
                                     var tags = System.Text.Json.JsonSerializer.Deserialize<string[]>(clip.TagsJson) ?? Array.Empty<string>();
                                     // Debug log to capture AI errors in console
                                     if (tags.Length > 0 && tags[0].StartsWith("Error"))
                                     {
                                         Console.WriteLine($"[AI-DEBUG] Tag Error for {clip.Title}: {tags[0]}");
                                     }
                                 }
                                 @foreach (var tag in tags.Take(3))
                                 {
                                     <a href="/search?q=@tag" @onclick:stopPropagation="true" class="badge text-decoration-none" style="background: var(--bg-dark-900); color: var(--text-secondary); border: 1px solid var(--border-color); font-weight: 500; font-size: 0.65rem; padding: 0.15rem 0.4rem;">
                                         @tag
                                     </a>
                                 }
                             </div>
                         }
                    <div class="video-info">
                        <div style="flex-grow: 1; min-width: 0;">
                            <div style="font-weight: 600; font-size: 1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@clip.Title">@clip.Title</div>
                             <div style="font-size: 0.85rem; color: var(--accent-cyan); margin-top: 0.1rem; font-weight: 500; display: flex; gap: 0.5rem; align-items: center;">
                                 @if (clip.RecordingStartedAt.HasValue)
                                 {
                                     <span style="color: var(--text-secondary);">@clip.RecordingStartedAt.Value.ToString("MMM dd, h:mm tt")</span>
                                     <span style="color: var(--text-muted); font-size: 0.7rem; margin: 0 0.3rem;">•</span>
                                 }
                                 @if (clip.DurationSec.HasValue)
                                 {
                                     <span>@TimeSpan.FromSeconds(clip.DurationSec.Value).ToString(@"mm\:ss")</span>
                                 }
                                 else if (!clip.RecordingStartedAt.HasValue)
                                 {
                                     <span style="color: var(--text-muted); font-style: italic;">Processing...</span>
                                 }
                             </div>
                        </div>
                        <span class="price-tag" style="align-self: flex-start; margin-top: 0.2rem;">$@(clip.PriceCents / 100.00)</span>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Event? _event;
    private bool _loading = true;
    private string? _watermarkUrl;
    private string _sortBy = "TimeUsedAsc"; // Default sort
    private Dictionary<string, string> _tokenCache = new();
    private bool _showCopiedMessage = false;
    private HashSet<string> _cartItemIds = new();

    private async Task CopyLinkAsync()
    {
        var uri = Navigation.Uri;
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", uri);
        _showCopiedMessage = true;
        StateHasChanged();
        await Task.Delay(2000);
        _showCopiedMessage = false;
        StateHasChanged();
    }

    private async Task ShareEventAsync()
    {
        var uri = Navigation.Uri;
        try 
        {
            await JSRuntime.InvokeVoidAsync("navigator.share", new { title = _event?.Name ?? "Project65 Event", url = uri });
        }
        catch 
        {
            // Fallback to copy link if share not supported or cancelled
            await CopyLinkAsync();
        }
    }

    private void NavigateToClip(string clipId)
    {
        Navigation.NavigateTo($"/clips/{clipId}");
    }

    private bool IsInCart(string clipId)
    {
        return _cartItemIds.Contains(clipId);
    }

    private async Task ToggleCart(Clip clip)
    {
        if (IsInCart(clip.Id))
        {
            await CartService.RemoveAsync(clip.Id);
            _cartItemIds.Remove(clip.Id);
        }
        else
        {
            var item = new Project65.Web.Models.CartItem
            {
                Id = clip.Id,
                Title = clip.Title,
                PriceCents = clip.PriceCents,
                DurationSec = clip.DurationSec,
                PlaybackId = clip.PlaybackIdSigned,
                EventId = clip.EventId
            };
            await CartService.AddAsync(item);
            _cartItemIds.Add(clip.Id);
        }
    }

    public void Dispose()
    {
        CartService.OnChange -= OnCartChanged;
    }

    private void OnCartChanged()
    {
        UpdateCartState();
        StateHasChanged();
    }

    private void UpdateCartState()
    {
        _cartItemIds = CartService.GetItems().Select(i => i.Id).ToHashSet();
    }

    protected override async Task OnInitializedAsync()
    {
        _watermarkUrl = await SettingsRepository.GetValueAsync("WatermarkUrl");
        _event = await EventRepository.GetByIdAsync(Id);
        
        if (_event?.Clips != null)
        {
            SortClips(); 
            
            // ---------------------------------------------------------
            // SELF-HEALING LOGIC (Matches ClipDetails.razor)
            // ---------------------------------------------------------
            // Identify clips that look broken (uploaded but no playback ID)
            var brokenClips = _event.Clips.Where(c => 
                string.IsNullOrEmpty(c.PlaybackIdSigned) && 
                !string.IsNullOrEmpty(c.MuxUploadId)
            ).ToList();

            if (brokenClips.Any())
            {
                // Fix them NOW (before page load finishes)
                foreach (var clip in brokenClips)
                {
                    await TryRepairClipAsync(clip);
                }
            }
            // ---------------------------------------------------------

            // Valid clips should now have IDs, load tokens
            foreach (var clip in _event.Clips)
            {
                var pid = string.IsNullOrEmpty(clip.PlaybackIdTeaser) ? clip.PlaybackIdSigned : clip.PlaybackIdTeaser;
                if (!string.IsNullOrEmpty(pid) && !pid.StartsWith("mock"))
                {
                    await LoadTokensForClip(pid);
                }
            }
        }
        
        _loading = false;
    }

    private async Task TryRepairClipAsync(Clip clip)
    {
        try
        {
            bool needsUpdate = false;

            // 1. Resolve Asset ID
            if (string.IsNullOrEmpty(clip.MuxAssetId))
            {
                var assetId = await VideoService.GetAssetIdFromUploadAsync(clip.MuxUploadId!);
                if (!string.IsNullOrEmpty(assetId))
                {
                    clip.MuxAssetId = assetId;
                    needsUpdate = true;
                }
            }

            // 2. Resolve Playback ID & Metadata
            if (!string.IsNullOrEmpty(clip.MuxAssetId))
            {
                if (string.IsNullOrEmpty(clip.PlaybackIdSigned))
                {
                    var newId = await VideoService.EnsurePlaybackIdAsync(clip.MuxAssetId);
                    if (!string.IsNullOrEmpty(newId))
                    {
                        clip.PlaybackIdSigned = newId;
                        needsUpdate = true;
                    }
                }

                if (!clip.DurationSec.HasValue || !clip.RecordingStartedAt.HasValue)
                {
                    var (duration, startedAt) = await VideoService.GetAssetDetailsAsync(clip.MuxAssetId);
                    if (duration.HasValue && !clip.DurationSec.HasValue) { clip.DurationSec = duration; needsUpdate = true; }
                    if (startedAt.HasValue && !clip.RecordingStartedAt.HasValue) { clip.RecordingStartedAt = startedAt; needsUpdate = true; }
                }
            }

            if (needsUpdate)
            {
                // We use the injected ClipRepository directly (Main Thread)
                // This updates the ACTUAL object _event.Clips references because EF tracks it
                await InvokeAsync(async () => {
                     // We need a tiny separate scope or repo to avoid conflict with EventRepo reading?
                     // Actually, since EventRepository is Scoped and tracks these entities, 
                     // we should use a specific update method on the entities.
                     // But simpler: just update the clip using a fresh scope to be safe,
                     // OR rely on the fact that we modified the entity in memory and _event references it.
                     
                     // Best approach: Just update it.
                     using var scope = ScopeFactory.CreateScope();
                     var repo = scope.ServiceProvider.GetRequiredService<IClipRepository>();
                     await repo.UpdateAsync(clip);
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[EventDetails] Repair failed for {clip.Id}: {ex.Message}");
        }
    }

@inject IServiceScopeFactory ScopeFactory

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            CartService.OnChange += OnCartChanged;
            await CartService.InitializeAsync();
             // Initial check
            UpdateCartState();
            StateHasChanged();

            if (_event?.Clips != null)
            {
                // Start continuous self-healing for any processing clips
                _ = ContinuousSelfHealAsync();
            }
        }
    }

    private async Task ContinuousSelfHealAsync()
    {
        await JSRuntime.InvokeVoidAsync("console.log", "[EventDetails] Starting continuous self-healing...");

        // Try for up to 3 minutes
        for (int i = 0; i < 36; i++)
        {
            if (_event?.Clips == null) break;

            // Clips needing repair: No PlaybackId but has UploadId
            // OR Missing Metadata (Duration or StartedAt)
            var brokenClips = _event.Clips.Where(c => 
                (string.IsNullOrEmpty(c.PlaybackIdSigned) && string.IsNullOrEmpty(c.PlaybackIdTeaser) && !string.IsNullOrEmpty(c.MuxUploadId))
                || (!c.RecordingStartedAt.HasValue && !string.IsNullOrEmpty(c.MuxAssetId)) // NEW: Missing timestamp + has AssetID
            ).ToList();

            if (!brokenClips.Any()) 
            {
                 // Check one last time if we are done or if new clips appeared (unlikely without refresh)
                 if (i > 5) break; 
            }

            bool uiUpdated = false;

            foreach (var clip in brokenClips)
            {
                bool clipFixed = false;
                try
                {
                    await JSRuntime.InvokeVoidAsync("console.log", $"[EventDetails] Attempting to heal clip {clip.Title} ({clip.Id})...");

                    // 1. Try to fetch fresh data from DB first (fastest/cheapest)
                    using (var scope = ScopeFactory.CreateScope())
                    {
                        var repo = scope.ServiceProvider.GetRequiredService<IClipRepository>();
                        var freshClip = await repo.GetByIdAsync(clip.Id);
                        
                        if (freshClip != null && !string.IsNullOrEmpty(freshClip.PlaybackIdSigned))
                        {
                             // DB has it! Sync local
                             clip.PlaybackIdSigned = freshClip.PlaybackIdSigned;
                             clip.DurationSec = freshClip.DurationSec;
                             clip.MuxAssetId = freshClip.MuxAssetId;
                             clip.RecordingStartedAt = freshClip.RecordingStartedAt;
                             clipFixed = true;
                             await JSRuntime.InvokeVoidAsync("console.log", $"[EventDetails] Healed {clip.Title} from DB.");
                        }
                    }

                    // 2. If locally still broken, hit Mux API (Active Repair)
                    if (!clipFixed)
                    {
                        // A. Resolve Asset ID
                        if (string.IsNullOrEmpty(clip.MuxAssetId))
                        {
                            var assetId = await VideoService.GetAssetIdFromUploadAsync(clip.MuxUploadId!);
                            if (!string.IsNullOrEmpty(assetId))
                            {
                                clip.MuxAssetId = assetId;
                                // Save progress to DB
                                using var scope = ScopeFactory.CreateScope();
                                var repo = scope.ServiceProvider.GetRequiredService<IClipRepository>();
                                await repo.UpdateAsync(clip);
                            }
                        }

                        // B. Resolve Playback ID
                        if (!string.IsNullOrEmpty(clip.MuxAssetId))
                        {
                             var playbackId = await VideoService.EnsurePlaybackIdAsync(clip.MuxAssetId);
                             if (!string.IsNullOrEmpty(playbackId))
                             {
                                 clip.PlaybackIdSigned = playbackId;
                                 
                                 // C. Get Details
                                 var (duration, startedAt) = await VideoService.GetAssetDetailsAsync(clip.MuxAssetId);
                                 if (duration.HasValue) clip.DurationSec = duration;
                                 if (startedAt.HasValue) clip.RecordingStartedAt = startedAt;

                                 // Save complete fix to DB
                                 using var scope = ScopeFactory.CreateScope();
                                 var repo = scope.ServiceProvider.GetRequiredService<IClipRepository>();
                                 await repo.UpdateAsync(clip);
                                 
                                 clipFixed = true;
                                 await JSRuntime.InvokeVoidAsync("console.log", $"[EventDetails] Healed {clip.Title} via Mux API.");
                             }
                        }
                    }

                    // 3. If fixed, load tokens and mark for UI update
                    if (clipFixed)
                    {
                        var pid = string.IsNullOrEmpty(clip.PlaybackIdTeaser) ? clip.PlaybackIdSigned : clip.PlaybackIdTeaser;
                        await LoadTokensForClip(pid);
                        uiUpdated = true;
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"[EventDetails] Error healing {clip.Id}: {ex.Message}");
                }
            }

            if (uiUpdated)
            {
                SortClips();
                await InvokeAsync(StateHasChanged);
            }

            // Check more frequently at first (1s), then back off (2s, 5s)
            int delay = i < 10 ? 1000 : (i < 20 ? 2000 : 5000);
            await Task.Delay(delay); 
        }
    }

    private async Task LoadTokensForClip(string playbackId)
    {
        bool tokensAdded = false;

        // Video Token (v)
        if (!_tokenCache.ContainsKey($"{playbackId}-v"))
        {
            var token = await VideoService.GetPlaybackToken(playbackId, "v", "480p");
            if (!string.IsNullOrEmpty(token)) { _tokenCache[$"{playbackId}-v"] = token; tokensAdded = true; }
        }
            
        // Thumbnail Token (t)
        if (!_tokenCache.ContainsKey($"{playbackId}-t"))
        {
            var token = await VideoService.GetPlaybackToken(playbackId, "t", "480p");
            if (!string.IsNullOrEmpty(token)) { _tokenCache[$"{playbackId}-t"] = token; tokensAdded = true; }
        }

        // Storyboard Token (s)
        if (!_tokenCache.ContainsKey($"{playbackId}-s"))
        {
            var token = await VideoService.GetPlaybackToken(playbackId, "s", "480p");
            if (!string.IsNullOrEmpty(token)) { _tokenCache[$"{playbackId}-s"] = token; tokensAdded = true; }
        }

        if (tokensAdded)
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnSortChanged(ChangeEventArgs e)
    {
        _sortBy = e.Value?.ToString() ?? "TimeUsedAsc";
        SortClips();
    }

    private void SortClips()
    {
        if (_event?.Clips == null || !_event.Clips.Any()) return;

        switch (_sortBy)
        {
            case "TimeUsedAsc": // Default: Least to greatest time used
                _event.Clips = _event.Clips.OrderBy(c => c.RecordingStartedAt ?? DateTime.MaxValue).ToList();
                break;
            case "TimeUsedDesc":
                _event.Clips = _event.Clips.OrderByDescending(c => c.RecordingStartedAt ?? DateTime.MinValue).ToList();
                break;
            case "PriceLowHigh":
                _event.Clips = _event.Clips.OrderBy(c => c.PriceCents).ToList();
                break;
            case "PriceHighLow":
                _event.Clips = _event.Clips.OrderByDescending(c => c.PriceCents).ToList();
                break;
            case "DurationShortLong":
                _event.Clips = _event.Clips.OrderBy(c => c.DurationSec ?? double.MaxValue).ToList();
                break;
            case "DurationLongShort":
                _event.Clips = _event.Clips.OrderByDescending(c => c.DurationSec ?? double.MinValue).ToList();
                break;
            default:
                _event.Clips = _event.Clips.OrderBy(c => c.RecordingStartedAt ?? DateTime.MaxValue).ToList();
                break;
        }
    }

    private string GetHybridThumbnailUrl(Clip clip)
    {
        if (string.IsNullOrEmpty(clip.ThumbnailFileName)) return "";

        var localPath = Path.Combine(Environment.WebRootPath, "thumbnails", clip.ThumbnailFileName);
        if (File.Exists(localPath))
        {
            return $"/thumbnails/{clip.ThumbnailFileName}";
        }
        
        return StorageService.GetPresignedDownloadUrl($"thumbnails/{clip.ThumbnailFileName}");
    }

    private string GetThumbnailId(Clip clip)
    {
        return clip.PlaybackIdTeaser ?? clip.PlaybackIdSigned;
    }

    private string GetToken(Clip clip)
    {
        // This is only used for the static img src tag, which is rendered synchronously.
        // We can grab it from cache if available, or empty.
        var id = GetThumbnailId(clip);
        return GetTokenFromCache(id, "t");
    }
    
    private string GetTokenFromCache(string playbackId, string type)
    {
        return _tokenCache.TryGetValue($"{playbackId}-{type}", out var token) ? token : "";
    }

    private bool HasTokens(string playbackId)
    {
        return _tokenCache.TryGetValue($"{playbackId}-v", out var v) && !string.IsNullOrEmpty(v) && 
               _tokenCache.TryGetValue($"{playbackId}-t", out var t) && !string.IsNullOrEmpty(t) && 
               _tokenCache.TryGetValue($"{playbackId}-s", out var s) && !string.IsNullOrEmpty(s);
    }
}
