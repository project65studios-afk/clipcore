@page "/events/{Id}"
@using Project65.Core.Interfaces
@using Project65.Core.Entities
@inject IEventRepository EventRepository
@inject IVideoService VideoService
@inject ISettingsRepository SettingsRepository
@inject IStorageService StorageService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject Project65.Web.Services.CartService CartService
@inject IWebHostEnvironment Environment
@inject IPurchaseRepository PurchaseRepository
@using System.IO
@implements IDisposable

<PageTitle>@_event?.Name - Project65</PageTitle>

@if (_event == null)
{
    @if (_loading) { <p>Loading...</p> }
    else { <p>Event not found.</p> }
}
else
{
    <div class="mb-4">
        <a href="/" style="color: var(--text-secondary); font-size: 0.9rem;">← Back to Events</a>
    </div>

    <div style="background: var(--bg-dark-800); border-radius: var(--radius-lg); padding: 2rem; margin-bottom: 3rem; border: 1px solid var(--border-color);">
        <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem;">@_event.Name</h1>
        <div style="display: flex; gap: 1rem; color: var(--text-secondary); margin-bottom: 1.5rem;">
            <span>@_event.Date.ToLongDateString()</span>
            <span>•</span>
            <span>@_event.Clips.Count clips</span>
        </div>
        <p style="max-width: 600px; color: var(--text-secondary);">@_event.Summary</p>
        
        <div class="event-header-actions" style="margin-top: 1.5rem; display: flex; gap: 0.5rem; align-items: center;">
             <button class="btn-primary" @onclick="ShareEventAsync">Share Event</button>
             <button class="btn-secondary" @onclick="CopyLinkAsync">
                 @(_showCopiedMessage ? "Link Copied!" : "Copy Link")
             </button>
        </div>
    </div>
    
    <div class="mb-4 event-details-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3 class="section-title">All Clips</h3>
        <select class="form-control" style="width: auto;" @onchange="OnSortChanged" value="@_sortBy">
            <option value="TimeUsedAsc">Time Used: Oldest First</option>
            <option value="TimeUsedDesc">Time Used: Newest First</option>
            <option value="PriceLowHigh">Price: Low to High</option>
            <option value="PriceHighLow">Price: High to Low</option>
            <option value="DurationShortLong">Duration: Shortest First</option>
            <option value="DurationLongShort">Duration: Longest First</option>
        </select>
    </div>

    @if (!_event.Clips.Any())
    {
        <p>No clips available yet.</p>
    }
    else
    {
        <div class="video-grid">
            @foreach (var clip in _event.Clips)
            {
                <ClipCard Clip="clip" IsPurchased="_purchasedClipIds.Contains(clip.Id)" WatermarkUrl="@_watermarkUrl" />
            }
        </div>
    }
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Event? _event;
    private bool _loading = true;
    private string? _watermarkUrl;
    private string _sortBy = "TimeUsedAsc"; // Default sort
    private bool _showCopiedMessage = false;
    private HashSet<string> _purchasedClipIds = new();

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = null!;

    private async Task CopyLinkAsync()
    {
        var uri = Navigation.Uri;
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", uri);
        _showCopiedMessage = true;
        StateHasChanged();
        await Task.Delay(2000);
        _showCopiedMessage = false;
        StateHasChanged();
    }

    private async Task ShareEventAsync()
    {
        var uri = Navigation.Uri;
        try 
        {
            await JSRuntime.InvokeVoidAsync("navigator.share", new { title = _event?.Name ?? "Project65 Event", url = uri });
        }
        catch 
        {
            // Fallback to copy link if share not supported or cancelled
            await CopyLinkAsync();
        }
    }

    private void NavigateToClip(string clipId)
    {
        Navigation.NavigateTo($"/clips/{clipId}");
    }


    protected override async Task OnInitializedAsync()
    {
        _watermarkUrl = await SettingsRepository.GetValueAsync("WatermarkUrl");
        _event = await EventRepository.GetByIdAsync(Id);
        
        if (_event?.Clips != null)
        {
            SortClips(); 
            
            // ---------------------------------------------------------
            // SELF-HEALING LOGIC (Matches ClipDetails.razor)
            // ---------------------------------------------------------
            // Identify clips that look broken (uploaded but no playback ID)
            var brokenClips = _event.Clips.Where(c => 
                string.IsNullOrEmpty(c.PlaybackIdSigned) && 
                !string.IsNullOrEmpty(c.MuxUploadId)
            ).ToList();

            if (brokenClips.Any())
            {
                // Fix them NOW (before page load finishes)
                foreach (var clip in brokenClips)
                {
                    await TryRepairClipAsync(clip);
                }
            }
            // ---------------------------------------------------------

            // Valid clips should now have IDs
        }
        
        if (AuthenticationStateTask != null)
        {
            var authState = await AuthenticationStateTask;
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                var userIdStr = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                if (Guid.TryParse(userIdStr, out var userId))
                {
                    var purchases = await PurchaseRepository.GetByUserIdAsync(userId);
                    _purchasedClipIds = purchases.Select(p => p.ClipId).ToHashSet();
                }
            }
        }

        _loading = false;
    }

    private async Task TryRepairClipAsync(Clip clip)
    {
        try
        {
            bool needsUpdate = false;

            // 1. Resolve Asset ID
            if (string.IsNullOrEmpty(clip.MuxAssetId))
            {
                var assetId = await VideoService.GetAssetIdFromUploadAsync(clip.MuxUploadId!);
                if (!string.IsNullOrEmpty(assetId))
                {
                    clip.MuxAssetId = assetId;
                    needsUpdate = true;
                }
            }

            // 2. Resolve Playback ID & Metadata
            if (!string.IsNullOrEmpty(clip.MuxAssetId))
            {
                if (string.IsNullOrEmpty(clip.PlaybackIdSigned))
                {
                    var newId = await VideoService.EnsurePlaybackIdAsync(clip.MuxAssetId);
                    if (!string.IsNullOrEmpty(newId))
                    {
                        clip.PlaybackIdSigned = newId;
                        needsUpdate = true;
                    }
                }

                if (!clip.DurationSec.HasValue || !clip.RecordingStartedAt.HasValue)
                {
                    var (duration, startedAt) = await VideoService.GetAssetDetailsAsync(clip.MuxAssetId);
                    if (duration.HasValue && !clip.DurationSec.HasValue) { clip.DurationSec = duration; needsUpdate = true; }
                    if (startedAt.HasValue && !clip.RecordingStartedAt.HasValue) { clip.RecordingStartedAt = startedAt; needsUpdate = true; }
                }
            }

            if (needsUpdate)
            {
                // We use the injected ClipRepository directly (Main Thread)
                // This updates the ACTUAL object _event.Clips references because EF tracks it
                await InvokeAsync(async () => {
                     // We need a tiny separate scope or repo to avoid conflict with EventRepo reading?
                     // Actually, since EventRepository is Scoped and tracks these entities, 
                     // we should use a specific update method on the entities.
                     // But simpler: just update the clip using a fresh scope to be safe,
                     // OR rely on the fact that we modified the entity in memory and _event references it.
                     
                     // Best approach: Just update it.
                     using var scope = ScopeFactory.CreateScope();
                     var repo = scope.ServiceProvider.GetRequiredService<IClipRepository>();
                     await repo.UpdateAsync(clip);
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[EventDetails] Repair failed for {clip.Id}: {ex.Message}");
        }
    }

@inject IServiceScopeFactory ScopeFactory

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            CartService.OnChange += StateHasChanged;
            await CartService.InitializeAsync();
             // Initial check
            StateHasChanged();

            if (_event?.Clips != null)
            {
                // Start continuous self-healing for any processing clips
                _ = ContinuousSelfHealAsync();
            }
        }
    }

    private async Task ContinuousSelfHealAsync()
    {
        await JSRuntime.InvokeVoidAsync("console.log", "[EventDetails] Starting continuous self-healing...");

        // Try for up to 3 minutes
        for (int i = 0; i < 36; i++)
        {
            if (_event?.Clips == null) break;

            // Clips needing repair: No PlaybackId but has UploadId
            // OR Missing Metadata (Duration or StartedAt)
            var brokenClips = _event.Clips.Where(c => 
                (string.IsNullOrEmpty(c.PlaybackIdSigned) && string.IsNullOrEmpty(c.PlaybackIdTeaser) && !string.IsNullOrEmpty(c.MuxUploadId))
                || (!c.RecordingStartedAt.HasValue && !string.IsNullOrEmpty(c.MuxAssetId)) // NEW: Missing timestamp + has AssetID
            ).ToList();

            if (!brokenClips.Any()) 
            {
                 // Check one last time if we are done or if new clips appeared (unlikely without refresh)
                 if (i > 5) break; 
            }

            bool uiUpdated = false;

            foreach (var clip in brokenClips)
            {
                bool clipFixed = false;
                try
                {
                    await JSRuntime.InvokeVoidAsync("console.log", $"[EventDetails] Attempting to heal clip {clip.Title} ({clip.Id})...");

                    // 1. Try to fetch fresh data from DB first (fastest/cheapest)
                    using (var scope = ScopeFactory.CreateScope())
                    {
                        var repo = scope.ServiceProvider.GetRequiredService<IClipRepository>();
                        var freshClip = await repo.GetByIdAsync(clip.Id);
                        
                        if (freshClip != null && !string.IsNullOrEmpty(freshClip.PlaybackIdSigned))
                        {
                             // DB has it! Sync local
                             clip.PlaybackIdSigned = freshClip.PlaybackIdSigned;
                             clip.DurationSec = freshClip.DurationSec;
                             clip.MuxAssetId = freshClip.MuxAssetId;
                             clip.RecordingStartedAt = freshClip.RecordingStartedAt;
                             clipFixed = true;
                             await JSRuntime.InvokeVoidAsync("console.log", $"[EventDetails] Healed {clip.Title} from DB.");
                        }
                    }

                    // 2. If locally still broken, hit Mux API (Active Repair)
                    if (!clipFixed)
                    {
                        // A. Resolve Asset ID
                        if (string.IsNullOrEmpty(clip.MuxAssetId))
                        {
                            var assetId = await VideoService.GetAssetIdFromUploadAsync(clip.MuxUploadId!);
                            if (!string.IsNullOrEmpty(assetId))
                            {
                                clip.MuxAssetId = assetId;
                                // Save progress to DB
                                using var scope = ScopeFactory.CreateScope();
                                var repo = scope.ServiceProvider.GetRequiredService<IClipRepository>();
                                await repo.UpdateAsync(clip);
                            }
                        }

                        // B. Resolve Playback ID
                        if (!string.IsNullOrEmpty(clip.MuxAssetId))
                        {
                             var playbackId = await VideoService.EnsurePlaybackIdAsync(clip.MuxAssetId);
                             if (!string.IsNullOrEmpty(playbackId))
                             {
                                 clip.PlaybackIdSigned = playbackId;
                                 
                                 // C. Get Details
                                 var (duration, startedAt) = await VideoService.GetAssetDetailsAsync(clip.MuxAssetId);
                                 if (duration.HasValue) clip.DurationSec = duration;
                                 if (startedAt.HasValue) clip.RecordingStartedAt = startedAt;

                                 // Save complete fix to DB
                                 using var scope = ScopeFactory.CreateScope();
                                 var repo = scope.ServiceProvider.GetRequiredService<IClipRepository>();
                                 await repo.UpdateAsync(clip);
                                 
                                 clipFixed = true;
                                 await JSRuntime.InvokeVoidAsync("console.log", $"[EventDetails] Healed {clip.Title} via Mux API.");
                             }
                        }
                    }

                    // 3. If fixed, mark for UI update
                    if (clipFixed)
                    {
                        uiUpdated = true;
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"[EventDetails] Error healing {clip.Id}: {ex.Message}");
                }
            }

            if (uiUpdated)
            {
                SortClips();
                await InvokeAsync(StateHasChanged);
            }

            // Check more frequently at first (1s), then back off (2s, 5s)
            int delay = i < 10 ? 1000 : (i < 20 ? 2000 : 5000);
            await Task.Delay(delay); 
        }
    }

    private void OnSortChanged(ChangeEventArgs e)
    {
        _sortBy = e.Value?.ToString() ?? "TimeUsedAsc";
        SortClips();
    }

    private void SortClips()
    {
        if (_event?.Clips == null || !_event.Clips.Any()) return;

        switch (_sortBy)
        {
            case "TimeUsedAsc": // Default: Least to greatest time used
                _event.Clips = _event.Clips.OrderBy(c => c.RecordingStartedAt ?? DateTime.MaxValue).ToList();
                break;
            case "TimeUsedDesc":
                _event.Clips = _event.Clips.OrderByDescending(c => c.RecordingStartedAt ?? DateTime.MinValue).ToList();
                break;
            case "PriceLowHigh":
                _event.Clips = _event.Clips.OrderBy(c => c.PriceCents).ToList();
                break;
            case "PriceHighLow":
                _event.Clips = _event.Clips.OrderByDescending(c => c.PriceCents).ToList();
                break;
            case "DurationShortLong":
                _event.Clips = _event.Clips.OrderBy(c => c.DurationSec ?? double.MaxValue).ToList();
                break;
            case "DurationLongShort":
                _event.Clips = _event.Clips.OrderByDescending(c => c.DurationSec ?? double.MinValue).ToList();
                break;
            default:
                _event.Clips = _event.Clips.OrderBy(c => c.RecordingStartedAt ?? DateTime.MaxValue).ToList();
                break;
        }
    }

    public void Dispose()
    {
        CartService.OnChange -= StateHasChanged;
    }
}
