@page "/delivery/{OrderId}"
@using Project65.Core.Entities
@using Project65.Core.Interfaces
@inject IPurchaseRepository PurchaseRepository
@inject IStorageService StorageService
@inject NavigationManager Navigation
@layout Project65.Web.Components.Layout.MainLayout

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold mb-3">Your Order is Ready</h1>
                <p class="lead text-muted">
                    Below are the high-resolution master files for your order. 
                    <br><span class="small"><i class="bi bi-shield-lock me-1"></i> For security, these download links are temporary. If a link expires, simply **reload this page** to generate new ones.</span>
                </p>
                <div class="badge bg-dark text-secondary border border-secondary px-3 py-2 rounded-pill">
                    Order #@OrderId.Substring(OrderId.Length - 8).ToUpper()
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (_items == null || !_items.Any())
            {
                <div class="alert alert-warning text-center">
                    Order not found or no items available.
                </div>
            }
            else
            {
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                    <div class="card-header bg-primary text-white p-4 text-center border-0">
                        <i class="bi bi-cloud-download fs-1 mb-2"></i>
                        <h5 class="mb-0">@_items.Count Files Available</h5>
                    </div>
                    <div class="list-group list-group-flush">
                        @foreach (var item in _items)
                        {
                            <div class="list-group-item p-4 border-bottom-0 border-top border-secondary">
                                <div class="d-flex align-items-center justify-content-between">
                                    <div class="me-3 overflow-hidden">
                                        <h5 class="mb-1 text-truncate">@(item.Clip?.Title ?? item.Purchase.ClipTitle ?? "Deleted Clip")</h5>
                                        <div class="small text-muted mb-2">
                                            <i class="bi bi-file-earmark-film me-1"></i> @(item.Clip?.MasterFileName ?? "Master File")
                                        </div>
                                        @if (item.Clip?.Event != null)
                                        {
                                            <span class="badge bg-dark text-info border border-info-subtle">@item.Clip.Event.Name</span>
                                        }
                                        else if (!string.IsNullOrEmpty(item.Purchase.EventName))
                                        {
                                            <span class="badge bg-dark text-info border border-info-subtle">@item.Purchase.EventName</span>
                                        }
                                    </div>
                                    
                                    @if (!string.IsNullOrEmpty(item.DownloadUrl))
                                    {
                                        <a href="@item.DownloadUrl" target="_blank" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm" download>
                                            <span>Download</span>
                                            <i class="bi bi-download"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary" disabled>Processing...</button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-transparent p-4 text-center text-muted small border-top border-secondary">
                        Need help? Contact support with your Order ID.
                    </div>
                </div>
            }
            
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string OrderId { get; set; } = "";

    private List<DeliveryItem>? _items;
    private bool _isLoading = true;

    private class DeliveryItem
    {
        public Purchase Purchase { get; set; } = default!;
        public Clip Clip { get; set; } = default!;
        public string? DownloadUrl { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(OrderId))
        {
            _isLoading = false;
            return;
        }

        try
        {
            // Fetch all purchases for this Order ID (StripeSessionId)
            var allPurchases = await PurchaseRepository.ListAsync();
            var orderPurchases = allPurchases
                .Where(p => p.StripeSessionId == OrderId && p.FulfillmentStatus == FulfillmentStatus.Fulfilled)
                .ToList();

            if (orderPurchases.Any())
            {
                _items = new List<DeliveryItem>();

                foreach (var p in orderPurchases)
                {
                    if (p.Clip != null && !string.IsNullOrEmpty(p.Clip.MasterFileName))
                    {
                        var url = StorageService.GetPresignedDownloadUrl(p.Clip.MasterFileName);
                        _items.Add(new DeliveryItem
                        {
                            Purchase = p,
                            Clip = p.Clip,
                            DownloadUrl = url
                        });
                    }
                    else if (!string.IsNullOrEmpty(p.HighResDownloadUrl))
                    {
                         // Fallback to manual link if set
                        _items.Add(new DeliveryItem
                        {
                            Purchase = p,
                            Clip = p.Clip ?? new Clip { Title = p.ClipTitle ?? "Video Clip" },
                            DownloadUrl = p.HighResDownloadUrl
                        });
                    }
                    else if (p.Clip == null && !string.IsNullOrEmpty(p.HighResDownloadUrl)) // Redundant but safe
                    {
                        _items.Add(new DeliveryItem
                        {
                            Purchase = p,
                            Clip = new Clip { Title = p.ClipTitle ?? "Video Clip" },
                            DownloadUrl = p.HighResDownloadUrl
                        });
                    }
                }
            }
        }
        catch (Exception)
        {
            // Error loading delivery
            _isLoading = false;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
