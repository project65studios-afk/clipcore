@page "/Error"
@using System.Diagnostics
@inject ISettingsRepository SettingsRepository
@inject Project65.Web.Services.StoreSettingsService StoreSettingsService

<PageTitle>Error - @(_storeName ?? "Project65 Studios")</PageTitle>

<div class="container my-5 fade-in">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="glass-panel p-5 text-center">
                <i class="bi bi-exclamation-triangle text-danger display-1 mb-4"></i>
                <h1 class="text-danger mb-3">Oops!</h1>
                <h2 class="h5 mb-4" style="color: var(--text-main)">An error occurred while processing your request.</h2>

                @if (ShowRequestId)
                {
                    <div class="alert alert-secondary bg-transparent border-secondary text-muted d-inline-block">
                        <strong>Request ID:</strong> <code>@RequestId</code>
                    </div>
                }

                <div class="mt-4">
                    <a href="/" class="btn btn-primary px-4 py-2 rounded-pill">Return Home</a>
                </div>

                <div class="mt-5 text-start">
                    <h3 class="h6 text-muted">Development Mode Info (Visible only in Dev)</h3>
                    <p class="small text-muted mb-0">
                        Swapping to <strong>Development</strong> environment will display more detailed information.
                        <strong>Do not enable in deployed applications</strong> as it may result in displaying sensitive information from exceptions to end users.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .glass-panel {
        background: var(--glass-bg);
        backdrop-filter: var(--glass-blur);
        -webkit-backdrop-filter: var(--glass-blur);
        border: 1px solid var(--glass-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--glass-shadow);
    }
    
    .fade-in {
        animation: fadeIn 0.8s ease-out;
    }
    
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private string? _storeName;
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override async Task OnInitializedAsync()
    {
        _storeName = await StoreSettingsService.GetStoreNameAsync();
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
    }
}
