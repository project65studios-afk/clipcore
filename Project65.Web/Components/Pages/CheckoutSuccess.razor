@page "/checkout/success"
@rendermode RenderMode.InteractiveServer
@using Project65.Core.Entities
@using Project65.Core.Interfaces
@using Project65.Infrastructure.Data.Repositories
@inject IPaymentService PaymentService
@inject IPurchaseRepository PurchaseRepository
@inject IClipRepository ClipRepository
@inject Project65.Web.Services.CartService CartService
@inject IEmailService EmailService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IPromoCodeRepository PromoCodeRepository
@inject IAuditService AuditService
@inject Project65.Web.Services.EmailTemplateService EmailTemplateService
@inject Project65.Web.Services.OrderFulfillmentService OrderFulfillmentService
@inject IStorageService StorageService
@inject IVideoService VideoService
@inject IJSRuntime JS

<style>
    .success-card {
        max-width: 650px;
        margin: 4rem auto;
        background: var(--bg-surface);
        border-radius: 24px;
        border: 1px solid var(--border-color);
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
        animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .success-header {
        padding: 4rem 2rem 2.5rem;
        background: linear-gradient(180deg, rgba(6, 182, 212, 0.05) 0%, transparent 100%);
        text-align: center;
    }

    .confetti-icon {
        font-size: 4rem;
        margin-bottom: 1.5rem;
        display: inline-block;
        animation: bounce 2s infinite;
    }

    @@keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    .order-number-badge {
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        display: inline-block;
        margin: 1.5rem 0;
    }

    .processing-pulse {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(6, 182, 212, 0.1);
        color: var(--accent-primary);
        padding: 0.4rem 1rem;
        border-radius: 100px;
        font-size: 0.85rem;
        font-weight: 600;
        letter-spacing: 0.02em;
    }

    .pulse-dot {
        width: 8px;
        height: 8px;
        background: var(--accent-primary);
        border-radius: 50%;
        animation: pulse 1.5s infinite;
    }

    @@keyframes pulse {
        0% { transform: scale(0.9); opacity: 0.7; box-shadow: 0 0 0 0 rgba(6, 182, 212, 0.7); }
        70% { transform: scale(1); opacity: 1; box-shadow: 0 0 0 10px rgba(6, 182, 212, 0); }
        100% { transform: scale(0.9); opacity: 0.7; box-shadow: 0 0 0 0 rgba(6, 182, 212, 0); }
    }

    .purchased-item {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.25rem;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 16px;
        margin-bottom: 1rem;
        transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .purchased-item:hover {
        transform: translateX(4px);
        border-color: rgba(6, 182, 212, 0.3);
    }

    .item-thumb {
        width: 90px;
        aspect-ratio: 16/9;
        background: var(--bg-main);
        border-radius: 8px;
        overflow: hidden;
        flex-shrink: 0;
        border: 1px solid rgba(255,255,255,0.1);
    }

    .small {
        font-size: 0.85rem;
    }
</style>

@inject ISettingsRepository SettingsRepository
@inject Project65.Web.Services.StoreSettingsService StoreSettingsService
@implements IDisposable

<PageTitle>Order Confirmed - @(_storeName ?? "Project65 Studios")</PageTitle>

<div class="success-card">
    @if (_isValidating)
    {
        <div style="padding: 6rem 2rem; text-align: center;">
            <div class="spinner-border text-info mb-4" style="width: 3rem; height: 3rem;" role="status"></div>
            <h3 class="fw-bold">Validating Order...</h3>
            <p class="text-secondary">Securing your clips, please don't refresh.</p>
        </div>
    }
    else if (_success)
    {
        <div class="success-header">
            <div class="confetti-icon">🎉</div>
            <h1 class="fw-bold mb-2" style="font-size: 2.5rem;">Thank You!</h1>
            <p class="text-secondary" style="font-size: 1.1rem; max-width: 400px; margin: 0 auto;">
                Your order has been confirmed and our system is now processing your clips.
            </p>

            <div class="order-number-badge">
                <span class="text-muted small text-uppercase d-block mb-1" style="letter-spacing: 0.1em;">Order Number</span>
                <span class="fw-bold text-primary" style="font-size: 1.5rem; letter-spacing: 0.05em;">@(_purchases.FirstOrDefault()?.OrderId ?? "PROCESSING")</span>
            </div>
        </div>

        <div style="padding: 0 2.5rem 3rem;">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="m-0 fw-bold">Order Summary</h5>
                <div class="processing-pulse">
                    <span class="pulse-dot"></span>
                    Processing Clips
                </div>
            </div>

            <div class="purchase-list mb-5">
                @foreach (var p in _purchases)
                {
                    <div class="purchased-item">
                        <div class="item-thumb">
                            @if (!string.IsNullOrEmpty(p.ClipThumbnailFileName))
                            {
                                <img src="@ResolveThumbnailUrl(p.ClipThumbnailFileName)" style="width: 100%; height: 100%; object-fit: cover;" />
                            }
                            else
                            {
                                <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: var(--bg-surface);">
                                    <i class="bi bi-camera-video text-muted"></i>
                                </div>
                            }
                        </div>
                        <div style="flex-grow: 1;">
                            <div class="fw-bold mb-1">@(p.ClipTitle ?? $"Clip #{p.ClipId}")</div>
                            <div class="d-flex gap-2 align-items-center">
                                <div class="text-muted small">@p.EventName</div>
                                @if (p.IsGif)
                                {
                                    <span class="badge" style="background: var(--accent-secondary-dim); color: var(--accent-secondary); border: 1px solid currentColor; font-size: 0.65rem; text-transform: uppercase;">GIF License</span>
                                }
                                else
                                {
                                    <span class="badge" style="background: var(--accent-primary-dim); color: var(--accent-primary); border: 1px solid currentColor; font-size: 0.65rem; text-transform: uppercase;">@p.LicenseType</span>
                                }
                            </div>
                        </div>
                        @if (p.IsGif)
                        {
                            <div class="text-end">
                                <span class="badge bg-success-dim text-success mb-2 d-block small" style="font-size: 0.7rem; font-weight: 700;">READY NOW</span>
                                <button class="btn btn-sm btn-info fw-bold" style="color: #000; font-size: 0.75rem;" @onclick="() => DownloadGifAsync(p)">
                                    <i class="bi bi-filetype-gif me-1"></i> Download
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="text-info small fw-bold">Ready Soon</div>
                        }
                    </div>
                }
            </div>

            <div class="row g-4 mb-5">
                <div class="col-md-6">
                    <div class="p-4 h-100" style="background: rgba(255,255,255,0.03); border-radius: 16px; border: 1px solid rgba(255,255,255,0.05);">
                        <i class="bi bi-envelope-check text-primary mb-3 d-block" style="font-size: 1.5rem;"></i>
                        <h6 class="fw-bold">Step 1: Get Email</h6>
                        <p class="text-muted small m-0">We’ll send a link to your inbox as soon as fulfillment is complete.</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-4 h-100" style="background: rgba(255,255,255,0.03); border-radius: 16px; border: 1px solid rgba(255,255,255,0.05);">
                        <i class="bi bi-cloud-download text-primary mb-3 d-block" style="font-size: 1.5rem;"></i>
                        <h6 class="fw-bold">Step 2: Download</h6>
                        <p class="text-muted small m-0">
                            @if (_purchases.Any(p => p.IsGif))
                            {
                                <span>Access your custom GIFs and 4K master files directly from your dashboard or email link.</span>
                            }
                            else
                            {
                                <span>Access 4K master files directly from your dashboard or email link.</span>
                            }
                        </p>
                    </div>
                </div>
            </div>

            <div class="d-grid gap-3">
                <a href="/my-purchases" class="btn-primary py-3">View Order History</a>
                <a href="/" class="btn-secondary py-3">Continue Shopping</a>
            </div>

            <div class="mt-4 text-center">
                <p class="text-muted small">
                    Have questions? <a href="/faq" style="color: var(--accent-primary); text-decoration: none;">View FAQ</a> or 
                    <a href="mailto:support@project65.com" style="color: var(--accent-primary); text-decoration: none;">Contact Support</a>
                </p>
            </div>
        </div>
    }
    else
    {
        <div style="padding: 6rem 2rem; text-align: center;">
            <div style="font-size: 4rem; margin-bottom: 1.5rem;">⚠️</div>
            <h2 class="fw-bold mb-3">Verification Error</h2>
            <p class="text-secondary mb-2">
                 We're having trouble verifying your payment session. If you received a confirmation from Stripe, don't worry—your order is safe.
            </p>
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger mb-5 small py-2">
                    <i class="bi bi-exclamation-triangle me-2"></i> @(_errorMessage)
                </div>
            }
            <div class="d-grid">
                <a href="/cart" class="btn-secondary py-3">Return to Cart</a>
            </div>
        </div>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "session_id")]
    public string? SessionId { get; set; }

    private bool _isValidating = true;
    private bool _success = false;
    private string? _storeName;
    private string? _supportEmail;
    private List<Purchase> _purchases = new();

    protected override async Task OnInitializedAsync()
    {
        _storeName = await StoreSettingsService.GetStoreNameAsync();
        StoreSettingsService.OnChange += HandleSettingsChange;
        _supportEmail = await SettingsRepository.GetValueAsync("SupportEmail"); // Keep this line
        // The instruction implies a FinalizeOrder() method, but doesn't provide its content.
        // Assuming the original logic for processing the order should be called here or in OnAfterRenderAsync.
        // For now, keeping the original OnAfterRenderAsync logic for order processing.
    }

    private void HandleSettingsChange()
    {
        InvokeAsync(async () =>
        {
            _storeName = await StoreSettingsService.GetStoreNameAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        StoreSettingsService.OnChange -= HandleSettingsChange;
    }

    private string ResolveThumbnailUrl(string? fileName)
    {
        if (string.IsNullOrEmpty(fileName)) return "";
        if (fileName.StartsWith("http") || fileName.StartsWith("/")) return fileName;
        
        var cleanName = fileName.TrimStart('/');
        var storageKey = cleanName.StartsWith("thumbnails/") 
            ? cleanName 
            : $"thumbnails/{cleanName}";
            
        return StorageService.GetPresignedDownloadUrl(storageKey);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (string.IsNullOrEmpty(SessionId))
            {
                _isValidating = false;
                StateHasChanged();
                return;
            }

            await ProcessOrderAsync();
            StateHasChanged();
        }
    }

    private string? _errorMessage;

    private async Task ProcessOrderAsync()
    {
        try
        {
            // 1. Process Order via Service
            _purchases = await OrderFulfillmentService.FulfillOrderAsync(SessionId!);
            
            if (_purchases.Any())
            {
                // 3. Clear Cart (UI Specific)
                await CartService.InitializeAsync();
                await CartService.ClearAsync();

                _success = true;
            }
            else
            {
                _errorMessage = "No purchases found in this session.";
            }
        }
        catch (Exception ex)
        {
            _success = false;
            _errorMessage = ex.Message + (ex.InnerException != null ? " -> " + ex.InnerException.Message : "");
            Console.WriteLine($"[CHECKOUT ERROR] {ex}");
        }
        finally
        {
            _isValidating = false;
            // Force UI update since we are in AfterRender
        }
    }

    private async Task DownloadGifAsync(Purchase purchase)
    {
        var pid = purchase.Clip?.PlaybackIdSigned;
        if (string.IsNullOrEmpty(pid) && purchase.Clip != null) pid = purchase.Clip.PlaybackIdSigned;

        if (!string.IsNullOrEmpty(pid))
        {
            var start = purchase.GifStartTime ?? 0;
            var duration = (purchase.GifEndTime ?? 5) - start;
            if (duration <= 0) duration = 5;

            var url = VideoService.GetGifUrlAsync(pid, start, duration);
            await JS.InvokeVoidAsync("open", url, "_blank");
        }
    }
}
