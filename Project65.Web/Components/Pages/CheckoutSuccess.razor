@page "/checkout/success"
@using Project65.Core.Entities
@using Project65.Core.Interfaces
@using Project65.Infrastructure.Data.Repositories
@inject IPaymentService PaymentService
@inject IPurchaseRepository PurchaseRepository
@inject IClipRepository ClipRepository
@inject Project65.Web.Services.CartService CartService
@inject IEmailService EmailService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IPromoCodeRepository PromoCodeRepository
@inject IAuditService AuditService
@inject Project65.Web.Services.EmailTemplateService EmailTemplateService
@rendermode RenderMode.InteractiveServer

<PageTitle>Order Confirmed - Project65</PageTitle>

<div style="max-width: 600px; margin: 4rem auto; padding: 2rem; background: var(--bg-dark-800); border-radius: var(--radius-lg); border: 1px solid var(--border-color); text-align: center;">
    
    @if (_isValidating)
    {
        <div class="spinner-border text-primary mb-3" role="status"></div>
        <h3>Validating Order...</h3>
    }
    else if (_success)
    {
        <div style="font-size: 3rem; margin-bottom: 1rem;">🎉</div>
        <h1 class="mb-3">Thank You!</h1>
        <p style="color: var(--text-secondary); margin-bottom: 2rem;">
            Your payment was successful. You now have full access to your clips.
            <br/>A receipt has been sent to your email.
        </p>

        @if (!string.IsNullOrEmpty(SessionId))
        {
            <div class="bg-dark/50 border border-white/10 rounded-xl p-8 mb-8 text-center backdrop-blur-sm">
                <p class="text-white/40 text-sm uppercase tracking-widest mb-2">Order Number</p>
                <p class="text-3xl font-bold font-display text-primary tracking-wider">@(_purchases.FirstOrDefault()?.OrderId ?? "PROCESSING")</p>
            </div>
        }
        
        <div style="text-align: left; margin-bottom: 2rem; background: rgba(0,0,0,0.2); padding: 1rem; border-radius: var(--radius-md);">
            <h5 class="mb-3">Purchased Items:</h5>
            <ul style="padding-left: 1.25rem; color: var(--text-secondary);">
                @foreach (var p in _purchases)
                {
                    <li style="margin-bottom: 0.5rem;">
                        @(p.ClipTitle ?? $"Clip #{p.ClipId}")
                        <a href="/clips/@p.ClipId" style="color: var(--accent-cyan); margin-left: 0.5rem; font-size: 0.9rem;">View Now →</a>
                    </li>
                }
            </ul>
        </div>

        <a href="/" class="btn-primary" style="text-decoration: none;">Continue Shopping</a>

        <div style="margin-top: 2rem; font-size: 0.9rem; color: var(--text-secondary);">
            Have questions about your order? <a href="/faq" style="color: var(--accent-cyan); text-decoration: underline;">Read our FAQ</a>
        </div>
    }
    else
    {
        <div style="font-size: 3rem; margin-bottom: 1rem;">⚠️</div>
        <h1 class="mb-3">Something went wrong</h1>
        <p style="color: var(--text-secondary); margin-bottom: 2rem;">
             We couldn't verify your order details. If you were charged, please contact support.
        </p>
        <a href="/cart" class="btn-secondary">Return to Cart</a>
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "session_id")]
    public string? SessionId { get; set; }

    private bool _isValidating = true;
    private bool _success = false;
    private List<Purchase> _purchases = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (string.IsNullOrEmpty(SessionId))
            {
                _isValidating = false;
                StateHasChanged();
                return;
            }

            await ProcessOrderAsync();
            StateHasChanged();
        }
    }

    private async Task ProcessOrderAsync()
    {
        try
        {
            // 1. Get Purchases from Stripe Session
            var purchases = (await PaymentService.GetPurchasesFromSessionAsync(SessionId!)).ToList();
            
            if (purchases.Any())
            {
                // 2. Identify User
                var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                var user = authState.User;
                string? userId = null;

                if (user.Identity != null && user.Identity.IsAuthenticated)
                {
                    userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                }

                // Generate a unique 6-character short hash for this order
                var shortOrderId = Guid.NewGuid().ToString("N").Substring(0, 6).ToUpper();
                
                foreach (var p in purchases)
                {
                    if (p.UserId == null) p.UserId = userId; 
                    
                    // Only check duplication if we have a userId and ClipId
                    bool shouldAdd = true;
                    if (!string.IsNullOrEmpty(p.UserId) && !string.IsNullOrEmpty(p.ClipId))
                    {
                         if (await PurchaseRepository.HasPurchasedAsync(p.UserId, p.ClipId))
                         {
                             shouldAdd = false;
                         }
                    }

                    if (shouldAdd && !string.IsNullOrEmpty(p.ClipId))
                    {
                        p.FulfillmentStatus = FulfillmentStatus.Pending;
                        p.StripeSessionId = SessionId!;
                        p.OrderId = shortOrderId; 
                        p.CreatedAt = DateTime.UtcNow;

                        // Healing Snapshots: If Stripe metadata failed but clip exists in DB, populate snapshots
                        var dbClip = await ClipRepository.GetByIdAsync(p.ClipId!);
                        if (dbClip != null)
                        {
                            if (string.IsNullOrEmpty(p.ClipTitle)) p.ClipTitle = dbClip.Title;
                            if (string.IsNullOrEmpty(p.EventName)) p.EventName = dbClip.Event?.Name ?? "Event Name Missing in DB";
                            if (!p.EventDate.HasValue) p.EventDate = dbClip.Event?.Date;
                            if (!p.ClipRecordingStartedAt.HasValue) p.ClipRecordingStartedAt = dbClip.RecordingStartedAt;
                            if (!p.ClipDurationSec.HasValue) p.ClipDurationSec = dbClip.DurationSec;
                            if (string.IsNullOrEmpty(p.ClipMasterFileName)) p.ClipMasterFileName = dbClip.MasterFileName;
                            if (string.IsNullOrEmpty(p.ClipThumbnailFileName)) p.ClipThumbnailFileName = dbClip.ThumbnailFileName;
                            
                            Console.WriteLine($"[ORDER-HEAL] Healed {p.ClipId}. Event: {p.EventName}, Dur: {p.ClipDurationSec}");
                        }
                        else 
                        {
                            Console.WriteLine($"[ORDER-HEAL] WARNING: Clip {p.ClipId} not found in DB during healing!");
                        }

                        await PurchaseRepository.AddAsync(p);
                    }
                }

                _purchases = purchases;
                _success = true;

                // 3. Clear Cart
                await CartService.InitializeAsync();
                await CartService.ClearAsync();

                // 4. Handle Promo Code Usage
                var promoId = await PaymentService.GetPromoCodeIdFromSessionAsync(SessionId!);
                if (promoId.HasValue)
                {
                    await PromoCodeRepository.IncrementUsageAsync(promoId.Value);
                    var promo = await PromoCodeRepository.GetByIdAsync(promoId.Value);
                    await AuditService.LogActionAsync(
                        userId, 
                        null, 
                        "Apply Promo Code", 
                        "PromoCode", 
                        promoId.Value.ToString(), 
                        $"Code: {promo?.Code ?? "Unknown"} used in order {SessionId}");
                }

                // 5. Send Branded Email Receipt
                try
                {
                    var customerEmail = await PaymentService.GetCustomerEmailFromSessionAsync(SessionId!) ?? "customer@example.com";
                    var customerName = _purchases.FirstOrDefault()?.CustomerName ?? "Customer";
                    
                    var htmlBody = EmailTemplateService.GenerateOrderReceiptHtml(shortOrderId, _purchases, customerName);
                    await EmailService.SendEmailAsync(customerEmail, "Your Project65 Order Receipt", htmlBody);
                }
                catch (Exception emailEx)
                {
                    // Log the error but don't fail the whole page - the user already paid!
                    Console.WriteLine($"Failed to send receipt email: {emailEx.Message}");
                    await AuditService.LogActionAsync(
                        userId,
                        null,
                        "Email Receipt Failed",
                        "Email",
                        SessionId,
                        $"Error: {emailEx.Message}");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Order processing error: {ex}");
            _success = false;
        }
        finally
        {
            _isValidating = false;
            // Force UI update since we are in AfterRender
        }
    }
}
