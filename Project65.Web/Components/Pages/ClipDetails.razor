@page "/clips/{Id}"
@using Project65.Core.Entities
@using Project65.Core.Interfaces
@using Project65.Infrastructure.Data.Repositories
@using Microsoft.AspNetCore.WebUtilities
@using System.IO
@inject IClipRepository ClipRepository
@inject IVideoService VideoService
@inject IPaymentService PaymentService
@inject IPurchaseRepository PurchaseRepository
@inject NavigationManager Navigation
@inject ISettingsRepository SettingsRepository
@inject IJSRuntime JSRuntime
@inject Project65.Web.Services.CartService CartService
@rendermode RenderMode.InteractiveServer

<PageTitle>@_clip?.Title - Project65</PageTitle>

@if (_clip == null)
{
    @if (_loading) { <p>Loading...</p> }
    else { <p>Clip not found.</p> }
}
else
{
    <div style="max-width: 1000px; margin: 0 auto;">
        <div class="mb-4">
            <a href="/events/@_clip.EventId" style="color: var(--text-secondary);">← Back to Event</a>
        </div>
        
        <div class="clip-layout" style="display: grid; gap: 2rem;">
             <div>
                 <div id="player-container" class="video-player-container mobile-full-width" style="border: 1px solid var(--border-color); box-shadow: 0 0 40px rgba(0,0,0,0.5); position: relative;">
                    @if (!string.IsNullOrEmpty(_watermarkUrl))
                    {
                        <div class="watermark-overlay">
                            <img src="@_watermarkUrl" alt="Watermark" />
                        </div>
                    }

                    @if (_hasPurchased)
                    {
                         <mux-player
                            id="purchased-player"
                            playback-id="@_clip.PlaybackIdSigned"
                            playback-token="@GetTokenFromCache(_clip.PlaybackIdSigned, "v")"
                            thumbnail-token="@GetTokenFromCache(_clip.PlaybackIdSigned, "t")"
                            storyboard-token="@GetTokenFromCache(_clip.PlaybackIdSigned, "s")"
                            metadata-video-title="@_clip.Title"
                            primary-color="#06b6d4"
                            accent-color="#ec4899"
                            fullscreen-element="player-container"
                            style="width: 100%; height: 100%;"
                         ></mux-player>
                    }
                    else if (GetPreviewId() is string previewId)
                    {
                        <mux-player
                            id="preview-player"
                            playback-id="@previewId"
                            playback-token="@GetTokenFromCache(previewId, "v")"
                            thumbnail-token="@GetTokenFromCache(previewId, "t")"
                            storyboard-token="@GetTokenFromCache(previewId, "s")"
                            metadata-video-title="@_clip.Title (Preview)"
                            muted
                            autoplay
                            fullscreen-element="player-container"
                            style="width: 100%; height: 100%;"
                        ></mux-player>
                    }
                    else
                    {
                         <div style="width:100%;height:100%;background:linear-gradient(45deg, #1e293b, #0f172a);display:flex;align-items:center;justify-content:center;flex-direction:column; min-height: 400px; color: var(--text-muted);">
                             <p>Preview Unavailable (Processing or Mock)</p>
                         </div>
                    }
                </div>
            
            <h1 style="margin-top: 1.5rem; font-size: 1.5rem; margin-bottom: 0.25rem;">@_clip.Title</h1>
                <div class="clip-meta-row">
                    <p style="color: var(--text-secondary); margin: 0;">Published on @_clip.PublishedAt.ToString("MMMM dd, yyyy")</p>
                    @if (_clip.RecordingStartedAt.HasValue)
                    {
                        <span style="color: var(--text-muted); font-size: 0.8rem;">•</span>
                        <p style="color: var(--text-secondary); margin: 0;">Filmed: @_clip.RecordingStartedAt.Value.ToString("MMM dd, yyyy h:mm tt")</p>
                    }
                    <span style="color: var(--text-muted); font-size: 0.8rem;">•</span>
                    <span style="color: var(--accent-cyan); font-weight: 600; font-size: 0.9rem;">
                        @(_clip.DurationSec.HasValue ? TimeSpan.FromSeconds(_clip.DurationSec.Value).ToString(@"mm\:ss") : "--:--")
                    </span>
                </div>
            </div>
            
            <!-- Purchase / Details Column -->
            <div style="background: var(--bg-dark-800); padding: 1.5rem; border-radius: var(--radius-lg); border: 1px solid var(--border-color); height: fit-content;">
                <h3 class="mb-4">Purchase Clip</h3>
                
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; padding-bottom: 1rem; border-bottom: 1px solid var(--border-color);">
                    <span style="color: var(--text-secondary);">Price</span>
                    <div style="text-align: right;">
                        <AuthorizeView Roles="Admin">
                            <Authorized>
                                @if (_isEditingPrice)
                                {
                                    <div style="display: flex; gap: 0.5rem; align-items: center;">
                                        <div style="position: relative; display: flex; align-items: center;">
                                            <span style="position: absolute; left: 0.75rem; color: var(--text-muted);">$</span>
                                            <input type="number" step="0.01" class="form-control" style="width: 100px; padding: 0.4rem 0.5rem 0.4rem 1.6rem; height: auto; font-size: 0.9rem;" @bind="_editingPrice" />
                                        </div>
                                        <button class="btn-primary" style="padding: 0.4rem 0.75rem; font-size: 0.8rem;" @onclick="SavePriceAsync">Save</button>
                                        <button class="btn-secondary" style="padding: 0.4rem 0.75rem; font-size: 0.8rem;" @onclick="CancelEditPrice">Cancel</button>
                                    </div>
                                }
                                else
                                {
                                    <div style="display: flex; gap: 0.75rem; align-items: center;">
                                        <span style="font-weight: 700; font-size: 1.25rem;">$@(_clip.PriceCents / 100.00)</span>
                                        <button class="btn-secondary" style="padding: 0.25rem 0.5rem; font-size: 0.7rem; color: var(--accent-cyan); border-color: var(--accent-cyan-dim);" @onclick="ToggleEditPrice">Edit Price</button>
                                    </div>
                                }
                            </Authorized>
                            <NotAuthorized>
                                <div style="display: flex; flex-direction: column; align-items: flex-end;">
                                    <span style="font-weight: 700; font-size: 1.25rem;">$@(_clip.PriceCents / 100.00)</span>
                                    @if (_isAuthenticated)
                                    {
                                        <span style="font-size: 0.65rem; color: var(--text-muted); font-style: italic;">Admin rights required to edit</span>
                                    }
                                </div>
                            </NotAuthorized>
                        </AuthorizeView>
                    </div>
                </div>
                
                <div style="margin-bottom: 2rem;">
                    <span style="color: var(--text-secondary);">Duration</span>
                    <span style="float: right;">@(_clip.DurationSec.HasValue ? TimeSpan.FromSeconds(_clip.DurationSec.Value).ToString(@"mm\:ss") : "--:--")</span>
                </div>
                
                @if (!_hasPurchased)
                {
                    <div class="d-flex gap-2 mb-3">
                        <button class="btn-primary" style="width: 100%;" @onclick="BuyAsync">
                            Buy Now
                        </button>
                        @if (_isInCart)
                        {
                            <a href="/cart" class="btn-secondary" style="width: 100%; text-align: center; text-decoration: none; display: flex; align-items: center; justify-content: center;">
                                In Cart →
                            </a>
                        }
                        else
                        {
                            <button class="btn-secondary" style="width: 100%;" @onclick="AddToCart" disabled="@_isAddingToCart">
                                @if (_isAddingToCart)
                                {
                                    <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="margin-right: 0.5rem;"></span>
                                    <span>Adding...</span>
                                }
                                else
                                {
                                    <span>Add to Cart</span>
                                }
                            </button>
                        }
                    </div>
                    @if (_processingPurchase)
                    {
                        <div class="text-center text-info">Verifying purchase...</div>
                    }
                    <p style="font-size: 0.8rem; color: var(--text-muted); text-align: center;">
                        Secure payment via Stripe. Instant access.
                    </p>
                }
                else
                {
                    <button class="btn-secondary" style="width: 100%; border-color: var(--accent-cyan); color: var(--accent-cyan);" disabled>
                         ✓ Purchased
                    </button>
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-warning mt-2 mb-0" style="font-size: 0.85rem; padding: 0.5rem;">@_errorMessage</div>
                    }
                    <button class="btn-primary mt-2" style="width: 100%;" @onclick="DownloadOriginalAsync" disabled="@_isDownloading">
                        @if (_isDownloading)
                        {
                             <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true" style="margin-right: 0.5rem;"></span>
                             <span>Preparing Download...</span>
                        }
                        else
                        {
                             <span>Download Source (2048p)</span>
                        }
                    </button>
                    <p style="font-size: 0.8rem; color: var(--text-muted); text-align: center; margin-top: 0.5rem;">
                        High-quality MP4 file.
                    </p>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Clip? _clip;
    private bool _loading = true;
    private bool _hasPurchased = false; 
    private bool _processingPurchase = false;
    private Guid _userId = Guid.NewGuid(); // TODO: Use ClaimsPrincipal
    private bool _isAuthenticated = false;

    private bool _isEditingPrice = false;
    private double _editingPrice;
    private string? _watermarkUrl;
    private string _errorMessage = "";
    private Dictionary<string, string> _tokenCache = new();

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = null!;

    private void ToggleEditPrice()
    {
        if (_clip != null)
        {
            _editingPrice = _clip.PriceCents / 100.00;
            _isEditingPrice = true;
        }
    }

    private void CancelEditPrice() => _isEditingPrice = false;

    private async Task SavePriceAsync()
    {
        if (_clip != null)
        {
            _clip.PriceCents = (int)Math.Round(_editingPrice * 100);
            await ClipRepository.UpdateAsync(_clip);
            _isEditingPrice = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _watermarkUrl = await SettingsRepository.GetValueAsync("WatermarkUrl");
        
        if (AuthenticationStateTask != null)
        {
            var authState = await AuthenticationStateTask;
            var user = authState.User;
            _isAuthenticated = user.Identity?.IsAuthenticated == true;
            
            if (_isAuthenticated)
            {
                 var userIdClaim = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                 if (Guid.TryParse(userIdClaim, out var parsed)) 
                 {
                     _userId = parsed;
                 }
            }
        }

        _clip = await ClipRepository.GetByIdAsync(Id);
        
        if (_clip != null)
        {
             // Self-Healing Logic (Repair PlaybackId/Duration)
            if (string.IsNullOrEmpty(_clip.MuxAssetId) && !string.IsNullOrEmpty(_clip.MuxUploadId))
            {
                var resolvedAssetId = await VideoService.GetAssetIdFromUploadAsync(_clip.MuxUploadId);
                if (!string.IsNullOrEmpty(resolvedAssetId))
                {
                    _clip.MuxAssetId = resolvedAssetId;
                    await ClipRepository.UpdateAsync(_clip);
                    Console.WriteLine($"Resolved and saved MuxAssetId for clip {_clip.Id}");
                }
            }

            if (!string.IsNullOrEmpty(_clip.MuxAssetId) && (string.IsNullOrEmpty(_clip.PlaybackIdSigned) || !_clip.DurationSec.HasValue || !_clip.RecordingStartedAt.HasValue))
            {
                // ... (Keep existing repair logic) ...
                 try 
                {
                    bool needsUpdate = false;
                    
                    if (string.IsNullOrEmpty(_clip.PlaybackIdSigned))
                    {
                        Console.WriteLine($"Repairing playback ID for Asset {_clip.MuxAssetId}");
                        var newId = await VideoService.EnsurePlaybackIdAsync(_clip.MuxAssetId);
                        if (!string.IsNullOrEmpty(newId))
                        {
                            _clip.PlaybackIdSigned = newId;
                            needsUpdate = true;
                        }
                    }

                    if (!_clip.DurationSec.HasValue || !_clip.RecordingStartedAt.HasValue)
                    {
                        var (duration, startedAt) = await VideoService.GetAssetDetailsAsync(_clip.MuxAssetId);
                        
                        if (duration.HasValue && !_clip.DurationSec.HasValue)
                        {
                            _clip.DurationSec = duration.Value;
                            needsUpdate = true;
                        }

                        if (startedAt.HasValue && !_clip.RecordingStartedAt.HasValue)
                        {
                            _clip.RecordingStartedAt = startedAt;
                            needsUpdate = true;
                        }
                    }

                    if (needsUpdate)
                    {
                        await ClipRepository.UpdateAsync(_clip); 
                    }
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Failed to repair asset: {ex.Message}");
                }
            }

            _hasPurchased = await PurchaseRepository.HasPurchasedAsync(_userId, Id);
            
            // Purchase Verification Logic
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            if (QueryHelpers.ParseQuery(uri.Query).TryGetValue("session_id", out var sessionId))
            {
                _processingPurchase = true;
                var purchases = await PaymentService.GetPurchasesFromSessionAsync(sessionId!);
                var purchase = purchases.FirstOrDefault(p => p.ClipId == Id);
                
                if (purchase != null)
                {
                    purchase.UserId = _userId;
                    if (!_hasPurchased)
                    {
                        try 
                        {
                            await PurchaseRepository.AddAsync(purchase);
                            _hasPurchased = true;
                        }
                        catch { _hasPurchased = true; }
                    }
                }
                _processingPurchase = false;
            }

            // LOAD TOKENS
            string targetId = "";
            string? resolution = null;
            
            if (_hasPurchased && !string.IsNullOrEmpty(_clip.PlaybackIdSigned))
            {
                targetId = _clip.PlaybackIdSigned;
                resolution = null; // Full quality, tracked
            }
            else if (GetPreviewId() is string pid)
            {
                targetId = pid;
                resolution = "480p"; // Preview, unlimited
            }

            if (!string.IsNullOrEmpty(targetId))
            {
                await LoadTokensForClip(targetId, resolution);
            }
        }
        _loading = false;
    }

    private async Task LoadTokensForClip(string playbackId, string? resolution = null)
    {
        if (!_tokenCache.ContainsKey($"{playbackId}-v"))
            _tokenCache[$"{playbackId}-v"] = await VideoService.GetPlaybackToken(playbackId, "v", resolution);
        
        if (!_tokenCache.ContainsKey($"{playbackId}-t"))
            _tokenCache[$"{playbackId}-t"] = await VideoService.GetPlaybackToken(playbackId, "t");

        if (!_tokenCache.ContainsKey($"{playbackId}-s"))
            _tokenCache[$"{playbackId}-s"] = await VideoService.GetPlaybackToken(playbackId, "s");
    }

    private string GetTokenFromCache(string playbackId, string type)
    {
        return _tokenCache.TryGetValue($"{playbackId}-{type}", out var token) ? token : "";
    }

    private string? GetPreviewId()
    {
        if (_clip == null) return null;
        if (!string.IsNullOrEmpty(_clip.PlaybackIdTeaser) && !_clip.PlaybackIdTeaser.StartsWith("mock"))
            return _clip.PlaybackIdTeaser;
        if (!string.IsNullOrEmpty(_clip.PlaybackIdSigned) && !_clip.PlaybackIdSigned.StartsWith("mock"))
            return _clip.PlaybackIdSigned;
        return null;
    }

    private bool _isInCart = false;
    private bool _isAddingToCart = false;

    private async Task BuyAsync()
    {
        if (_clip == null) return;
        var successUrl = Navigation.BaseUri + $"clips/{Id}?session_id={{CHECKOUT_SESSION_ID}}";
        var cancelUrl = Navigation.BaseUri + $"clips/{Id}";
        
        string? userEmail = null;
        if (AuthenticationStateTask != null)
        {
            var authState = await AuthenticationStateTask;
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                userEmail = user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? user.Identity.Name;
            }
        }

        // Pass single item as list
        var url = await PaymentService.CreateCheckoutSessionAsync(new[] { _clip }, successUrl, cancelUrl, userEmail);
        Navigation.NavigateTo(url);
    }

    private bool _isDownloading = false;

    private async Task DownloadOriginalAsync()
    {
        if (_clip == null || string.IsNullOrEmpty(_clip.MuxAssetId)) return;

        _isDownloading = true;
        _errorMessage = "";
        StateHasChanged();

        // Sanitize filename
        var cleanTitle = string.Join("_", _clip.Title.Split(Path.GetInvalidFileNameChars()));
        var url = await VideoService.GetDownloadUrlAsync(_clip.MuxAssetId, $"{cleanTitle}.mp4");
        
        if (!string.IsNullOrEmpty(url))
        {
            // Verify availability
            using var client = new System.Net.Http.HttpClient();
            try 
            {
                var request = new System.Net.Http.HttpRequestMessage(System.Net.Http.HttpMethod.Head, url);
                var response = await client.SendAsync(request);
                
                if (response.IsSuccessStatusCode)
                {
                    await JSRuntime.InvokeVoidAsync("open", url, "_blank");
                }
                else
                {
                    _errorMessage = "Source file is verifying. Please try again in 1-2 minutes.";
                }
            }
            catch
            {
                 // Fallback
                 _errorMessage = "Source file check failed. Please retry shortly.";
            }
        }
        else
        {
             _errorMessage = "Requesting source file from vault... Please wait 30-60s and try again.";
        }

        _isDownloading = false;
        StateHasChanged();
    }

    private async Task AddToCart()
    {
        if (_clip != null && !_isAddingToCart)
        {
            _isAddingToCart = true;
            try
            {
                await CartService.AddAsync(_clip);
                _isInCart = true;
            }
            finally
            {
                _isAddingToCart = false;
                StateHasChanged();
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _clip != null)
        {
            await CartService.InitializeAsync();
             // Check if already in cart
            _isInCart = CartService.GetItems().Any(c => c.Id == _clip.Id);
            StateHasChanged();

            try
            {
                if (_hasPurchased)
                {
                    await JSRuntime.InvokeVoidAsync("setFullscreenElement", "#purchased-player", "player-container");
                }
                else if (GetPreviewId() != null)
                {
                    await JSRuntime.InvokeVoidAsync("setFullscreenElement", "#preview-player", "player-container");
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"JS Error: {ex.Message}");
            }
        }
    }
}
