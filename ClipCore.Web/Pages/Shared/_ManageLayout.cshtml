@using Microsoft.AspNetCore.Components.Web
@using ClipCore.Web.Components.Layout
@using ClipCore.Web.Components
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <title>@ViewData["Title"] - ClipCore Studios</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="/app.css" />
    <link rel="stylesheet" href="/ClipCore.Web.styles.css" />
    <link rel="stylesheet" href="/lib/bootstrap-icons/font/bootstrap-icons.min.css">
    <script>
        (function() {
            const theme = localStorage.getItem('theme');
            if (theme === 'light') document.documentElement.classList.add('light-theme');
        })();
    </script>
    <component type="typeof(DynamicTheme)" render-mode="Server" />
</head>
<body class="bg-main text-main">
    <header>
        <component type="typeof(TopNav)" render-mode="Server" />
    </header>

    <main class="content-container" style="padding-top: 2rem;">
        <div class="identity-container">
            <div class="identity-card" style="max-width: 1200px;">
                <div class="row">
                    <div class="col-md-12">
                        <h1 class="mb-4">Manage your account</h1>
                        <hr style="border-color: var(--border-color); opacity: 0.1;" />
                    </div>
                </div>
                <div class="row mt-4">
                    <div class="col-md-3">
                        <partial name="~/Areas/Identity/Pages/Account/Manage/_ManageNav.cshtml" />
                    </div>
                    <div class="col-md-9 px-md-4">
                        @RenderBody()
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script src="/lib/jquery/dist/jquery.min.js"></script>
    <script src="/_framework/blazor.web.js"></script>
    <script src="/js/theme.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
