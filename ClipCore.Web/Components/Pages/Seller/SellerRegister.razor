@page "/seller/register"
@rendermode RenderMode.InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using System.Security.Claims
@attribute [Authorize]
@inject ClipCore.Web.Services.SellerService SellerService
@inject NavigationManager Navigation

<PageTitle>Become a Seller — ClipCore</PageTitle>

<div class="container py-5" style="max-width: 600px;">
    <div class="mb-4">
        <h1 class="h3 fw-bold mb-1">Become a Seller</h1>
        <p class="text-secondary">Set up your storefront and start selling your clips.</p>
    </div>

    @if (_alreadySeller)
    {
        <div class="alert alert-info">
            You already have a seller account. <a href="/seller/dashboard">Go to your dashboard →</a>
        </div>
    }
    else if (_success)
    {
        <div class="alert alert-success">
            <strong>You're in!</strong> Your storefront has been created.
            <a href="/seller/dashboard" class="alert-link ms-2">Go to your dashboard →</a>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                @if (!string.IsNullOrEmpty(_error))
                {
                    <div class="alert alert-danger">@_error</div>
                }

                <!-- Slug -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Store URL <span class="text-danger">*</span></label>
                    <div class="input-group">
                        <span class="input-group-text text-secondary">@Navigation.BaseUri.TrimEnd('/')/@("store/")</span>
                        <input class="form-control @(_slugError != null ? "is-invalid" : _slugOk ? "is-valid" : "")"
                               @bind="_slug"
                               @bind:event="oninput"
                               @oninput="OnSlugInput"
                               placeholder="your-store-name"
                               maxlength="30" />
                    </div>
                    @if (_slugError != null)
                    {
                        <div class="text-danger small mt-1">@_slugError</div>
                    }
                    else if (_slugOk)
                    {
                        <div class="text-success small mt-1">✓ Available</div>
                    }
                    <div class="form-text">Lowercase letters, numbers, and hyphens only. This cannot be changed later.</div>
                </div>

                <!-- Display Name -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Display Name <span class="text-danger">*</span></label>
                    <input class="form-control" @bind="_displayName" placeholder="e.g. Apex Motorsport Media" maxlength="80" />
                    <div class="form-text">This is shown to buyers on your storefront.</div>
                </div>

                <!-- Bio -->
                <div class="mb-4">
                    <label class="form-label fw-bold">Bio <span class="text-secondary fw-normal">(optional)</span></label>
                    <textarea class="form-control" @bind="_bio" rows="3" placeholder="Tell buyers who you are and what you shoot..." maxlength="500"></textarea>
                </div>

                <div class="d-grid mt-2">
                    <button class="btn btn-primary btn-lg" @onclick="Submit" disabled="@_submitting">
                        @(_submitting ? "Creating your store..." : "Create My Store")
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = null!;

    private string _slug = "";
    private string _displayName = "";
    private string? _bio;

    private string? _slugError;
    private bool _slugOk;
    private string? _error;
    private bool _submitting;
    private bool _success;
    private bool _alreadySeller;
    private string? _userId;

    private System.Timers.Timer? _debounceTimer;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateTask;
        _userId = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (_userId != null && authState.User.IsInRole("Seller"))
            _alreadySeller = true;
    }

    private void OnSlugInput(ChangeEventArgs e)
    {
        _slug = e.Value?.ToString() ?? "";
        _slugOk = false;
        _slugError = null;

        // Debounce uniqueness check
        _debounceTimer?.Stop();
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Timers.Timer(400);
        _debounceTimer.Elapsed += async (_, _) =>
        {
            _debounceTimer?.Dispose();
            await InvokeAsync(ValidateSlugAsync);
        };
        _debounceTimer.AutoReset = false;
        _debounceTimer.Start();
    }

    private async Task ValidateSlugAsync()
    {
        var (valid, error) = SellerService.ValidateSlug(_slug);
        if (!valid)
        {
            _slugError = error;
            _slugOk = false;
            StateHasChanged();
            return;
        }

        // Check uniqueness via SellerService (calls StorefrontRepository)
        // We do a lightweight check by attempting a dry-run via the service's static validator first
        // Full uniqueness check happens on submit; here we show "Available" optimistically after format passes
        _slugOk = true;
        _slugError = null;
        StateHasChanged();
    }

    private async Task Submit()
    {
        if (string.IsNullOrWhiteSpace(_slug) || string.IsNullOrWhiteSpace(_displayName))
        {
            _error = "Store URL and Display Name are required.";
            return;
        }

        if (_userId == null)
        {
            _error = "You must be logged in.";
            return;
        }

        _submitting = true;
        _error = null;

        var (success, error) = await SellerService.RegisterSellerAsync(_userId, _slug, _displayName, _bio);

        if (success)
        {
            _success = true;
        }
        else
        {
            _error = error;
            _submitting = false;
        }
    }
}
