@page "/delivery/{OrderId}"

@using ClipCore.Core.Entities
@using ClipCore.Core.Interfaces
@inject IPurchaseRepository PurchaseRepository
@inject IStorageService StorageService
@inject NavigationManager Navigation
@inject ISettingsRepository SettingsRepository
@implements IDisposable
@inject ClipCore.Web.Services.StoreSettingsService StoreSettingsService
@inject IVideoService VideoService
@inject IJSRuntime JSRuntime

<PageTitle>Order Delivery - @(_storeName ?? "ClipCore Studios")</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold mb-3">Your Order is Ready</h1>
                <p class="lead" style="color: var(--text-main); font-weight: 500;">
                    Below are the high-resolution master files for your order. 
                    <br><span class="small" style="color: var(--text-secondary); opacity: 0.9;"><i class="bi bi-shield-lock me-1"></i> For security, these download links are temporary. If a link expires, simply **reload this page** to generate new ones.</span>
                </p>
                <div class="d-flex justify-content-center align-items-center gap-2 mt-3">
                    <div class="badge bg-dark text-secondary border border-secondary px-3 py-2 rounded-pill">
                        Order #@((OrderId.Length >= 8 ? OrderId.Substring(OrderId.Length - 8) : OrderId).ToUpper())
                    </div>
                    <button class="btn btn-sm btn-outline-secondary rounded-pill" @onclick="RefreshPage" title="Refresh download links">
                        <i class="bi bi-arrow-clockwise me-1"></i> Refresh Links
                    </button>
                </div>
            </div>

            @if (_isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                </div>
            }
            else if (_items == null || !_items.Any())
            {
                <div class="alert alert-warning text-center">
                    Order not found or no items available.
                </div>
            }
            else
            {
                <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                    <div class="card-header bg-primary text-white p-4 text-center border-0">
                        <i class="bi bi-cloud-download fs-1 mb-2"></i>
                        <h5 class="mb-0">@(_items?.Count ?? 0) Files Available</h5>
                    </div>
                    <div class="list-group list-group-flush">
                        @if (_items != null) 
                        {
                            @foreach (var item in _items)
                            {
                                <div class="list-group-item p-4 border-bottom-0 border-top border-secondary">
                                    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                                    <div class="me-3 overflow-hidden w-100">
                                        <h5 class="mb-1 text-truncate" style="color: var(--text-main);">@(item.Clip?.Title ?? item.Purchase.ClipTitle ?? "Deleted Clip")</h5>
                                        <div class="d-flex gap-1 align-items-center flex-wrap">
                                            @if (item.Clip?.Event != null)
                                            {
                                                <span class="badge bg-dark text-info border border-info-subtle">@item.Clip!.Event!.Name</span>
                                            }
                                            else if (!string.IsNullOrEmpty(item.Purchase.CollectionName))
                                            {
                                                <span class="badge bg-dark text-info border border-info-subtle">@item.Purchase.CollectionName</span>
                                            }

                                            @if (item.Purchase.IsGif)
                                            {
                                                <span class="badge" style="background: var(--accent-secondary-dim); color: var(--accent-secondary); border: 1px solid currentColor; font-size: 0.7rem; text-transform: uppercase;">GIF License</span>
                                            }
                                            else
                                            {
                                                <span class="badge" style="background: var(--accent-primary-dim); color: var(--accent-primary); border: 1px solid currentColor; font-size: 0.7rem; text-transform: uppercase;">@item.Purchase.LicenseType License</span>
                                            }
                                        </div>
                                    </div>
                                    
                                    @if (item.Purchase.IsGif)
                                    {
                                        if (!string.IsNullOrEmpty(item.Purchase.BrandedPlaybackId))
                                        {
                                            <button class="btn btn-info d-flex align-items-center gap-2 shadow-sm pulse-hover" style="color: #000; background: linear-gradient(135deg, #0dcaf0, #0aa2c0); border: none;" @onclick="() => DownloadGifAsync(item.Purchase)">
                                                <span>Download GIF</span>
                                                <i class="bi bi-filetype-gif"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <div class="d-flex flex-column align-items-end gap-1">
                                                <button class="btn btn-outline-info d-flex align-items-center gap-2 opacity-75" disabled>
                                                    <span class="spinner-border spinner-border-sm" role="status"></span>
                                                    <span>Branding GIF...</span>
                                                </button>
                                                <span class="x-small text-info opacity-75">Creating your watermarked copy</span>
                                            </div>
                                        }
                                    }
                                    else if (!string.IsNullOrEmpty(item.DownloadUrl))
                                    {
                                        <a href="@item.DownloadUrl" target="_blank" class="btn btn-primary d-flex align-items-center gap-2 shadow-sm pulse-hover" style="background: linear-gradient(135deg, var(--accent-primary), var(--accent-primary-dim)); border: none;" download>
                                            <span>Download</span>
                                            <i class="bi bi-download"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-outline-secondary d-flex align-items-center gap-2" disabled>
                                            <span class="spinner-border spinner-border-sm" role="status"></span>
                                            <span>Processing...</span>
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                        }
                    </div>
                    <div class="card-footer bg-transparent p-4 text-center small border-top border-secondary" style="color: var(--text-secondary);">
                        Need help? Contact support with your Order ID.
                    </div>
                </div>
            }
            
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string OrderId { get; set; } = "";

    private List<DeliveryItem>? _items;
    private bool _isLoading = true;
    private string? _storeName;

    private class DeliveryItem
    {
        public Purchase Purchase { get; set; } = default!;
        public Clip Clip { get; set; } = default!;
        public string? DownloadUrl { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        _storeName = await StoreSettingsService.GetStoreNameAsync();
        StoreSettingsService.OnChange += HandleSettingsChange;
        
        await LoadOrder();
    }

    private async Task LoadOrder()
    {
        if (string.IsNullOrEmpty(OrderId))
        {
            _isLoading = false;
            return;
        }

        try
        {
            // Fetch all purchases for this Order ID (StripeSessionId) using optimized query
            var orderPurchases = await PurchaseRepository.GetBySessionIdAsync(OrderId);
            orderPurchases = orderPurchases
                .Where(p => p.FulfillmentStatus == FulfillmentStatus.Fulfilled)
                .ToList();

            if (orderPurchases.Any())
            {
                _items = new List<DeliveryItem>();

                foreach (var p in orderPurchases)
                {
                    // 1. Determine the best file key to use
                    // 1. Try R2 (Direct Storage)
                    string? targetKey = null;
                    if (!string.IsNullOrEmpty(p.ClipMasterFileName)) targetKey = p.ClipMasterFileName;
                    else if (p.Clip != null && !string.IsNullOrEmpty(p.Clip.MasterFileName)) targetKey = p.Clip.MasterFileName;

                    string? downloadUrl = null;
                    if (targetKey != null)
                    {
                        downloadUrl = StorageService.GetPresignedDownloadUrl(targetKey);
                        if (string.IsNullOrEmpty(downloadUrl)) Console.WriteLine($"[Delivery] R2 Link Generation Failed for {targetKey}");
                    }

                    // 2. Try Mux (Fallback if R2 failed or missing)
                    if (string.IsNullOrEmpty(downloadUrl) && !string.IsNullOrEmpty(p.FulfillmentMuxAssetId))
                    {
                        var fileName = p.Clip?.MasterFileName ?? p.ClipMasterFileName ?? p.Clip?.Title ?? p.ClipTitle ?? "video.mov";
                        if (!fileName.EndsWith(".mov", StringComparison.OrdinalIgnoreCase) && !fileName.EndsWith(".mp4", StringComparison.OrdinalIgnoreCase))
                        {
                            fileName += ".mov";
                        }
                        downloadUrl = await VideoService.GetDownloadUrlAsync(p.FulfillmentMuxAssetId, fileName);
                    }

                    // 3. Try Legacy URL (Last Resort)
                    if (string.IsNullOrEmpty(downloadUrl) && !string.IsNullOrEmpty(p.HighResDownloadUrl))
                    {
                        downloadUrl = p.HighResDownloadUrl;
                    }

                    // Add Item regardless (if null, will show "Processing")
                    _items.Add(new DeliveryItem
                    {
                        Purchase = p,
                        Clip = p.Clip ?? new Clip { Title = p.ClipTitle ?? "Video Clip" },
                        DownloadUrl = downloadUrl
                    });
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Delivery] Error loading order: {ex.Message}");
            // Error loading delivery
            _isLoading = false;
        }
        finally
        {
            _isLoading = false;
        }
    }
    
    private async Task DownloadGifAsync(Purchase purchase)
    {
        // 1. Prioritize Branded (Watermarked) Playback ID
        var pid = purchase.BrandedPlaybackId;
        
        // 2. Fallback to Original if branding not yet complete/available
        if (string.IsNullOrEmpty(pid)) pid = purchase.Clip?.PlaybackIdSigned;
        if (string.IsNullOrEmpty(pid) && purchase.Clip != null) pid = purchase.Clip.PlaybackIdSigned;

        if (!string.IsNullOrEmpty(pid))
        {
            var start = purchase.GifStartTime ?? 0;
            var duration = (purchase.GifEndTime ?? 5) - start;
            if (duration <= 0) duration = 5;

            var url = VideoService.GetGifUrlAsync(pid, start, duration);
            await JSRuntime.InvokeVoidAsync("open", url, "_blank");
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("alert", "GIF generation unavailable for this clip.");
        }
    }

    private void RefreshPage()
    {
        Navigation.Refresh(true);
    }
    
    private void HandleSettingsChange()
    {
        InvokeAsync(async () =>
        {
            _storeName = await StoreSettingsService.GetStoreNameAsync();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        StoreSettingsService.OnChange -= HandleSettingsChange;
    }
}
