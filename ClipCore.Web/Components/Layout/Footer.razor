@inject ClipCore.Web.Services.StoreSettingsService StoreSettingsService

<footer class="site-footer mt-auto py-4">
    <div class="container text-center">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <p class="small mb-2" style="color: var(--text-secondary)">
                    &copy; @DateTime.Now.Year @(_storeName ?? "ClipCore Studios"). All rights reserved.
                </p>
                <div class="footer-links">
                    <a href="/privacy" class="text-decoration-none mx-2 small hover-effect" style="color: var(--text-muted)">Privacy Policy</a>
                    <span class="small" style="color: var(--text-muted)">&middot;</span>
                    <a href="/terms" class="text-decoration-none mx-2 small hover-effect" style="color: var(--text-muted)">Terms of Service</a>
                </div>
            </div>
        </div>
    </div>
</footer>

<style>
    .site-footer {
        border-top: 1px solid var(--border-color);
        background: var(--bg-surface);
    }
    
    .hover-effect:hover {
        color: var(--text-main) !important;
        text-decoration: underline !important;
    }
</style>

@code {
    private string? _storeName;

    protected override async Task OnInitializedAsync()
    {
        _storeName = await StoreSettingsService.GetStoreNameAsync();
    }
}
